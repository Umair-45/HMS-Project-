<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        HMS Dashboard
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background:
                linear-gradient(rgba(5, 12, 30, 0.95),
                    rgba(5, 12, 30, 0.95)),
                url("https://images.unsplash.com/photo-1587351021759-3e566b6af7cc?q=80&w=2070&auto=format&fit=crop");
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            min-height: 100vh;
            font-family: "Segoe UI", -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
            display: flex;
            align-items: center;
            color: #ffffff;
        }

        .dashboard-card {
            background: rgba(10, 22, 50, 0.65);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-radius: 28px;
            padding: 50px;
            margin-top: 40px;
            margin-bottom: 40px;
            border: 1px solid rgba(255, 255, 255, 0.07);
            box-shadow:
                0 25px 60px rgba(0, 0, 0, 0.55),
                inset 0 1px 0 rgba(255, 255, 255, 0.1);
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 45px;
            flex-wrap: wrap;
            gap: 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            padding-bottom: 30px;
        }

        .dashboard-title {
            background: linear-gradient(135deg, #ffffff, #a3b8cc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 44px;
            font-weight: 800;
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }

        .welcome-text {
            color: #94a3b8;
            font-size: 18px;
            font-weight: 500;
        }

        .logout-btn {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            border: none;
            color: white;
            padding: 12px 24px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow:
                0 8px 20px rgba(239, 68, 68, 0.25);
        }

        .logout-btn:hover {
            transform: translateY(-2px);
            background: linear-gradient(135deg, #dc2626, #b91c1c);
            box-shadow: 0 10px 25px rgba(239, 68, 68, 0.35);
        }

        .menu-card {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 22px;
            padding: 35px 20px;
            text-align: center;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            cursor: pointer;
            text-decoration: none;
            display: block;
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.05);
            position: relative;
            overflow: hidden;
            height: 100%;
        }

        .menu-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
            transition: 0.6s;
        }

        .menu-card:hover::before {
            left: 100%;
        }

        .menu-card:hover {
            transform: translateY(-6px);
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(56, 189, 248, 0.4);
            box-shadow:
                0 15px 35px rgba(0, 0, 0, 0.3);
            color: white;
        }

        .menu-icon {
            width: 80px;
            height: 80px;
            margin: auto;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            margin-bottom: 22px;
            color: #ffffff;
            transition: transform 0.3s ease;
        }

        .menu-card:hover .menu-icon {
            transform: scale(1.1) rotate(3deg);
        }

        /* Specific gradient icons for each module */
        .icon-register {
            background: linear-gradient(135deg, #0284c7, #0369a1);
            box-shadow: 0 8px 20px rgba(2, 132, 199, 0.3);
        }
        .icon-slip {
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            box-shadow: 0 8px 20px rgba(99, 102, 241, 0.3);
        }
        .icon-reports {
            background: linear-gradient(135deg, #db2777, #be185d);
            box-shadow: 0 8px 20px rgba(219, 39, 119, 0.3);
        }
        .icon-expenses {
            background: linear-gradient(135deg, #ea580c, #c2410c);
            box-shadow: 0 8px 20px rgba(234, 88, 12, 0.3);
        }
        .icon-staff {
            background: linear-gradient(135deg, #059669, #047857);
            box-shadow: 0 8px 20px rgba(5, 150, 105, 0.3);
        }
        .icon-history {
            background: linear-gradient(135deg, #0d9488, #0f766e);
            box-shadow: 0 8px 20px rgba(13, 148, 136, 0.3);
        }

        .menu-title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 8px;
            color: #ffffff;
        }

        .menu-desc {
            color: #94a3b8;
            font-size: 14px;
            line-height: 1.5;
        }

        /* Patients History Card Section Styles */
        .patients-history-card {
            background: rgba(15, 23, 42, 0.45);
            border-radius: 24px;
            padding: 35px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            margin-top: 40px;
        }

        .card-header-custom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 20px;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .icon-wrap {
            width: 55px;
            height: 55px;
            background: linear-gradient(135deg, #0d9488, #0f766e);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            color: white;
            box-shadow: 0 8px 20px rgba(13, 148, 136, 0.25);
        }

        .section-title {
            color: #ffffff;
            font-size: 24px;
            font-weight: 700;
            margin: 0;
        }

        .total-badge {
            display: inline-block;
            background: rgba(13, 148, 136, 0.15);
            color: #2dd4bf;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 13px;
            font-weight: 600;
            border: 1px solid rgba(13, 148, 136, 0.3);
            margin-top: 5px;
        }

        .search-wrap {
            position: relative;
            width: 320px;
            max-width: 100%;
        }

        .search-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #64748b;
            font-size: 15px;
        }

        .search-input {
            width: 100%;
            padding: 10px 15px 10px 40px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            color: white;
            font-size: 14px;
            outline: none;
            transition: all 0.3s ease;
        }

        .search-input:focus {
            border-color: #0d9488;
            background: rgba(255, 255, 255, 0.07);
            box-shadow: 0 0 12px rgba(13, 148, 136, 0.2);
        }

        .table-container {
            overflow-x: auto;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.04);
            background: rgba(15, 23, 42, 0.2);
        }

        .custom-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .custom-table th {
            background: rgba(15, 23, 42, 0.5);
            color: #94a3b8;
            font-weight: 600;
            font-size: 14px;
            padding: 16px 20px;
            border-bottom: 2px solid rgba(255, 255, 255, 0.06);
        }

        .custom-table td {
            color: #e2e8f0;
            padding: 14px 20px;
            font-size: 14px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        }

        .custom-table tbody tr {
            transition: all 0.2s ease;
        }

        .custom-table tbody tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .mr-badge {
            background: rgba(13, 148, 136, 0.1);
            color: #2dd4bf;
            padding: 4px 10px;
            border-radius: 8px;
            font-family: monospace;
            font-weight: 700;
            border: 1px solid rgba(13, 148, 136, 0.15);
        }

        @media(max-width:768px) {
            .dashboard-title {
                font-size: 34px;
            }

            .dashboard-card {
                padding: 30px 20px;
            }

            .top-bar {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>

</head>

<body>

    <div class="container">

        <div class="dashboard-card">

            <div class="top-bar">

                <div>

                    <h1 class="dashboard-title">
                        Maida Hospital Dashboard
                    </h1>

                    <p class="welcome-text" id="welcomeText"></p>

                </div>

                <button class="logout-btn" onclick="logout()">
                    <i class="fa-solid fa-right-from-bracket"></i>
                    Logout
                </button>

            </div>


            <div class="row g-4">

                <div class="col-md-4">

                    <a href="/register-patient" class="menu-card">

                        <div class="menu-icon icon-register">
                            <i class="fa-solid fa-user"></i>
                        </div>

                        <div class="menu-title">
                            Register Patient
                        </div>

                        <div class="menu-desc">
                            Add and manage new patient records securely.
                        </div>

                    </a>

                </div>


                <div class="col-md-4">

                    <a href="/create-slip" class="menu-card">

                        <div class="menu-icon icon-slip">
                            <i class="fa-solid fa-file-waveform"></i>
                        </div>

                        <div class="menu-title">
                            Create Slip
                        </div>

                        <div class="menu-desc">
                            Generate patient slips quickly and efficiently.
                        </div>

                    </a>

                </div>


                <div class="col-md-4">

                    <a href="/reports" class="menu-card">

                        <div class="menu-icon icon-reports">
                            <i class="fa-solid fa-chart-line"></i>
                        </div>

                        <div class="menu-title">
                            Reports
                        </div>

                        <div class="menu-desc">
                            View hospital analytics and performance reports.
                        </div>

                    </a>

                </div>



                <div class="col-md-4">

                    <a href="/expenses" class="menu-card">

                        <div class="menu-icon icon-expenses">
                            <i class="fa-solid fa-wallet"></i>
                        </div>

                        <div class="menu-title">
                            Expenses
                        </div>

                        <div class="menu-desc">
                            Manage hospital expenses, bills, salary and profit/loss reports.
                        </div>

                    </a>

                </div>




                <div class="col-md-4">

                    <a href="/staff" class="menu-card">

                        <div class="menu-icon icon-staff">
                            <i class="fa-solid fa-user-doctor"></i>
                        </div>

                        <div class="menu-title">
                            Staff Management
                        </div>

                        <div class="menu-desc">
                            Manage hospital staff, salaries, allowances and payroll slips.
                        </div>

                    </a>

                </div>


                <div class="col-md-4" id="patientsHistoryCardCol">

                    <div onclick="togglePatientsHistory()" class="menu-card" id="patientsHistoryCardBtn">

                        <div class="menu-icon icon-history">
                            <i class="fa-solid fa-users"></i>
                        </div>

                        <div class="menu-title">
                            Patients History
                        </div>

                        <div class="menu-desc">
                            View registered patients, search records, and view history.
                        </div>

                    </div>

                </div>

            </div>

            <!-- PATIENTS HISTORY DETAILS BOX -->
            <div class="patients-history-card" id="patientsHistorySection" style="display: none;">
                <div class="card-header-custom">
                    <div class="header-left">
                        <div class="icon-wrap">
                            <i class="fa-solid fa-users"></i>
                        </div>
                        <div>
                            <h2 class="section-title">Patients History</h2>
                            <span class="total-badge" id="totalPatientsCount">Total Patients: 0</span>
                        </div>
                    </div>
                    <div class="search-wrap">
                        <i class="fa-solid fa-magnifying-glass search-icon"></i>
                        <input type="text" id="patientSearchInput" placeholder="Search by Name, MR#, or Phone..." class="search-input">
                    </div>
                </div>
                <div class="table-container">
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>MR Number</th>
                                <th>Patient Name</th>
                                <th>Guardian</th>
                                <th>Phone</th>
                                <th>Age / Gender</th>
                                <th>Address</th>
                                <th>Registered Date</th>
                            </tr>
                        </thead>
                        <tbody id="patientsTableBody">
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">Loading patient data...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>

    </div>


 <script>

    const user =
        JSON.parse(
            localStorage.getItem("user")
        );

    const isAdmin =
        user?.role === "ADMIN";


    // WELCOME TEXT :
    document.getElementById(
        "welcomeText"
    ).innerText =

        `Welcome ${user.username} (${user.role})`;

    let patientsData = [];

    async function fetchPatients() {
        const token = localStorage.getItem("token");
        try {
            const response = await fetch("/api/patient/getAllPatients", {
                headers: {
                    Authorization: `Bearer ${token}`
                }
            });
            const result = await response.json();
            if (result.success) {
                patientsData = result.data || [];
                renderPatientsTable(patientsData);
                document.getElementById("totalPatientsCount").innerText = `Total Patients: ${result.total || patientsData.length}`;
            } else {
                console.error("Failed to fetch patients:", result.message);
            }
        } catch (error) {
            console.error("Error fetching patients:", error);
        }
    }

    function renderPatientsTable(data) {
        const tbody = document.getElementById("patientsTableBody");
        if (!data || data.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" class="text-center py-4 text-muted">No patients found</td></tr>';
            return;
        }
        
        let rows = [];
        data.forEach(patient => {
            const dateStr = new Date(patient.createdAt).toLocaleDateString();
            const genderBadge = patient.gender === "Male" ? "gender-badge gender-male" : "gender-badge gender-female";
            rows.push(`
                <tr>
                    <td><span class="mr-badge">${patient.mrNumber || ""}</span></td>
                    <td><strong>${patient.patientName || ""}</strong></td>
                    <td>${patient.guardianName || "N/A"}</td>
                    <td>${patient.phone || "N/A"}</td>
                    <td>${patient.age || ""} / <span class="${genderBadge}">${patient.gender || ""}</span></td>
                    <td>${patient.address || "N/A"}</td>
                    <td>${dateStr}</td>
                </tr>
            `);
        });
        tbody.innerHTML = rows.join("");
    }

    function togglePatientsHistory() {
        const section = document.getElementById("patientsHistorySection");
        if (section.style.display === "none") {
            section.style.display = "block";
            fetchPatients();
            section.scrollIntoView({ behavior: "smooth" });
        } else {
            section.style.display = "none";
        }
    }

    document.getElementById("patientSearchInput").addEventListener("keyup", (e) => {
        const searchVal = e.target.value.toLowerCase();
        const filtered = patientsData.filter(patient => {
            const name = (patient.patientName || "").toLowerCase();
            const mr = (patient.mrNumber || "").toLowerCase();
            const phone = (patient.phone || "").toLowerCase();
            return name.includes(searchVal) || mr.includes(searchVal) || phone.includes(searchVal);
        });
        renderPatientsTable(filtered);
    });

    // HIDE MODULES FOR OPERATOR
    if (!isAdmin) {

        // REPORTS HIDE
        const reportsCard =
            document.querySelector(
                'a[href="/reports"]'
            )?.parentElement;

        if (reportsCard) {
            reportsCard.style.display = "none";
        }


        // EXPENSES HIDE
        const expenseCard =
            document.querySelector(
                'a[href="/expenses"]'
            )?.parentElement;

        if (expenseCard) {
            expenseCard.style.display = "none";
        }


        // STAFF HIDE
        const staffCard =
            document.querySelector(
                'a[href="/staff"]'
            )?.parentElement;

        if (staffCard) {
            staffCard.style.display = "none";
        }

        // PATIENTS HISTORY HIDE
        const patientsHistoryCard = document.getElementById("patientsHistoryCardCol");
        if (patientsHistoryCard) {
            patientsHistoryCard.style.display = "none";
        }
        const patientsHistorySection = document.getElementById("patientsHistorySection");
        if (patientsHistorySection) {
            patientsHistorySection.style.display = "none";
        }

    }


    // LOGOUT :
    function logout() {

        localStorage.removeItem("token");

        localStorage.removeItem("user");

        window.location.href = "/";

    }

</script>

</body>

</html>