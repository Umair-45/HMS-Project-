<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        HMS Expenses
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>
        * {

            margin: 0;

            padding: 0;

            box-sizing: border-box;

        }

        body {

            background:
                linear-gradient(rgba(5, 15, 35, 0.94),
                    rgba(5, 15, 35, 0.94)),

                url('https://images.unsplash.com/photo-1505751172876-fa1923c5c528?q=80&w=1600&auto=format&fit=crop');

            background-size: cover;

            background-position: center;

            background-attachment: fixed;

            min-height: 100vh;

            font-family: "Segoe UI", sans-serif;

            padding: 30px 0;

        }

        .main-card {

            background: rgba(10, 20, 45, 0.82);

            backdrop-filter: blur(16px);

            border-radius: 30px;

            padding: 40px;

            border: 1px solid rgba(255, 255, 255, 0.08);

            box-shadow:
                0 15px 40px rgba(0, 0, 0, 0.45);

            color: white;

        }

        .page-title {

            font-size: 48px;

            font-weight: 700;

            color: white;

        }

        .dashboard-btn {

            background:
                linear-gradient(135deg,
                    #00c6ff,
                    #0072ff);

            color: white;

            border: none;

            padding: 12px 24px;

            border-radius: 14px;

            text-decoration: none;

            font-weight: 600;

            transition: 0.3s ease;

            box-shadow:
                0 10px 25px rgba(0, 114, 255, 0.35);

        }

        .dashboard-btn:hover {

            transform: translateY(-3px);

            color: white;

        }

        .section-card {

            background: rgba(255, 255, 255, 0.05);

            border-radius: 24px;

            padding: 25px;

            border: 1px solid rgba(255, 255, 255, 0.08);

            margin-top: 30px;

        }

        .section-title {

            font-size: 24px;

            font-weight: 700;

            margin-bottom: 20px;

        }

        .form-control,
        .form-select {

            background: rgba(255, 255, 255, 0.10);

            border: 1px solid rgba(255, 255, 255, 0.08);

            border-radius: 14px;

            color: white;

            padding: 14px;

        }

        .form-control:focus,
        .form-select:focus {

            background: rgba(255, 255, 255, 0.14);

            color: white;

            border: 1px solid #00c6ff;

            box-shadow:
                0 0 0 4px rgba(0, 198, 255, 0.15);

        }

        .form-control::placeholder {

            color: #d8e2f0;

        }

        .form-select option {

            color: black;

        }

        .form-label {

            margin-bottom: 10px;

            font-weight: 600;

            color: #dce6f8;

        }

        .submit-btn {

            width: 100%;

            border: none;

            border-radius: 16px;

            padding: 16px;

            font-size: 16px;

            font-weight: 700;

            color: white;

            background:
                linear-gradient(135deg,
                    #00c6ff,
                    #0072ff);

            transition: 0.3s ease;

            box-shadow:
                0 10px 25px rgba(0, 114, 255, 0.35);

        }

        .submit-btn:hover {

            transform: translateY(-4px);

        }

        .expense-card {

            background: rgba(255, 255, 255, 0.06);

            border-radius: 22px;

            padding: 24px;

            margin-top: 20px;

            border-left: 5px solid #00c6ff;

        }

        .expense-title {

            font-size: 22px;

            font-weight: 700;

            margin-bottom: 20px;

        }

        .info-grid {

            display: grid;

            grid-template-columns:
                repeat(auto-fit,
                    minmax(220px, 1fr));

            gap: 18px;

        }

        .info-box {

            background: rgba(255, 255, 255, 0.05);

            border-radius: 16px;

            padding: 18px;

        }

        .info-label {

            font-size: 13px;

            color: #aebbd3;

            margin-bottom: 8px;

            text-transform: uppercase;

            letter-spacing: 1px;

        }

        .info-value {

            font-size: 18px;

            font-weight: 700;

            color: white;

            word-break: break-word;

        }

        .alert {

            border-radius: 18px;

            border: none;

            padding: 18px;

            font-size: 16px;

        }

        .alert-success {

            background: rgba(25, 135, 84, 0.18);

            color: #b8ffd8;

        }

        .alert-danger {

            background: rgba(220, 53, 69, 0.18);

            color: #ffd7dc;

        }

        hr {

            border-color: rgba(255, 255, 255, 0.10);

        }

        .hospital-print {

            display: none;

        }

        @media print {

            body {

                width: 100%;
                height: auto !important;

                margin: 0 !important;
                padding: 0 !important;

                background: white !important;

                overflow: hidden !important;

                zoom: 88%;
            }

            @page {

                size: A4 portrait;

                margin: 8mm;

            }

            /* HIDE UNNECESSARY UI */

            .dashboard-btn,
            .submit-btn,
            form,
            .page-title,
            hr,
            .section-card:not(:last-of-type) {

                display: none !important;

            }

            /* MAIN CARD */

            .main-card {

                background: white !important;

                color: black !important;

                box-shadow: none !important;

                border: none !important;

                border-radius: 0 !important;

                padding: 0 !important;

                margin: 0 !important;

            }

            /* SECTION */

            .section-card {

                background: white !important;

                border: none !important;

                margin: 0 !important;

                padding: 0 !important;

            }

            /* RESULT AREA */

            #expenseResult {

                margin: 0 !important;

                padding: 0 !important;

            }

            /* REPORT CARD */

            .expense-card {

                width: 100% !important;

                background: white !important;

                color: black !important;

                border: 1px solid #cfcfcf !important;

                border-radius: 10px !important;

                padding: 12px !important;

                margin: 0 auto !important;

                page-break-inside: avoid !important;

                break-inside: avoid !important;

            }

            /* TABLE */

            table {

                width: 100% !important;

                border-collapse: collapse !important;

                font-size: 11px !important;

            }

            table th,
            table td {

                border: 1px solid #bbb !important;

                padding: 4px 6px !important;

                color: black !important;

            }

            table th {

                background: #efefef !important;

                font-weight: 700 !important;

            }

            /* TEXT */

            h1,
            h2,
            h3,
            h4,
            h5,
            h6,
            p,
            span,
            div {

                color: black !important;

            }

            h2,
            h5 {

                margin: 0 !important;

                padding: 0 !important;

            }

            /* HOSPITAL HEADER */

            .hospital-print {

                display: block !important;

                text-align: center;

                margin-bottom: 10px !important;

            }

            .hospital-print h1 {

                font-size: 24px !important;

                font-weight: 800 !important;

                margin-bottom: 2px !important;

            }

            .hospital-print h3 {

                font-size: 14px !important;

                margin: 0 !important;

                font-weight: 600 !important;

            }

            /* REMOVE EXTRA SPACING */

            .expense-title,
            .section-title {

                margin-bottom: 8px !important;

            }

        }

        @media(max-width:768px) {

            .page-title {

                font-size: 34px;

            }

            .main-card {

                padding: 24px;

            }

        }
    </style>

</head>

<body>

    <div class="container">

        <div class="main-card">

            <div class="hospital-print">

                <h1>
                    MAIDA HOSPITAL
                </h1>

                <h3>
                    Monthly Expense & Profit Report
                </h3>

                <hr>

            </div>

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                <h1 class="page-title">
                    Hospital Expenses
                </h1>

                <a href="/dashboard" class="dashboard-btn">

                    <i class="fa-solid fa-table-columns"></i>

                    Dashboard

                </a>

            </div>

            <hr>

            <!-- REPORT BUTTONS -->

            <div class="section-card">

                <div class="section-title">
                    Expense Reports
                </div>

                <div class="row g-4">

                    <div class="col-md-3">

                        <button class="submit-btn" onclick="loadExpenses()">

                            <i class="fa-solid fa-wallet"></i>

                            All Expenses

                        </button>

                    </div>

                    <div class="col-md-3">

                        <button class="submit-btn" onclick="dailyExpenseReport()">

                            <i class="fa-solid fa-calendar-day"></i>

                            Daily Expense

                        </button>

                    </div>

                    <div class="col-md-3">

                        <button class="submit-btn" onclick="monthlyExpenseReport()">

                            <i class="fa-solid fa-chart-column"></i>

                            Monthly Expense

                        </button>

                    </div>

                    <div class="col-md-3">

                        <button class="submit-btn" onclick="categoryExpenseReport()">

                            <i class="fa-solid fa-layer-group"></i>

                            Categories

                        </button>

                    </div>

                    <div class="col-md-3">

                        <button class="submit-btn" onclick="monthlySalaryExpenseReport()">

                            <i class="fa-solid fa-money-bill-wave"></i>

                            Salary Report

                        </button>

                    </div>

                    <div class="col-md-3">

                        <button class="submit-btn" onclick="dailyProfitLossReport()">

                            <i class="fa-solid fa-chart-line"></i>

                            Daily Profit / Loss

                        </button>

                    </div>

                    <div class="col-md-3">

                        <button class="submit-btn" onclick="profitLossReport()">

                            <i class="fa-solid fa-chart-line"></i>

                            Monthly Profit / Loss

                        </button>

                    </div>

                    <div class="col-md-3">

                        <button class="submit-btn" onclick="window.print()">

                            <i class="fa-solid fa-print"></i>

                            Print Report

                        </button>

                    </div>

                </div>

            </div>

            <!-- FORM -->

            <div class="section-card">

                <div class="section-title">
                    Add New Expense
                </div>

                <div id="messageBox" class="alert d-none"></div>

                <form id="expenseForm">

                    <div class="row g-4">

                        <div class="col-md-6">

                            <label class="form-label">
                                Expense Category
                            </label>

                            <select name="category" class="form-select" required>

                                <option value="">
                                    Select Category
                                </option>

                                <option value="DOCTOR_PAYMENT">Doctors payment</option>
                                <option value="ANESTHETIC_PAYMENT">Anesthetic payment</option>
                                <option value="UTILITY_BILLS">Utility bills</option>
                                <option value="KITCHEN_PAYMENT">Kitchen payment</option>
                                <option value="HOME_EXPENSE">Home expenses</option>
                                <option value="MEDICAL_STORE_BILLS">Medical store bills</option>
                                <option value="SURGICAL_MATERIAL">Surgical material</option>
                                <option value="BUILDING_REPAIR">Building repair</option>
                                <option value="MONTHLY_SALARY">Monthly salary</option>
                                <option value="EXCISE_TAX">Excise tax</option>
                                <option value="INCOME_TAX">Income tax</option>
                                <option value="CONTONMENT_TAX">Contonment tax</option>
                                <option value="HEALTH_CARE_COMMISSION">Health care commission</option>
                                <option value="EQUIPMENT_REPAIR">Equipment repair</option>
                                <option value="WASTE_MANAGEMENT">Waste management</option>
                                <option value="NURSERY_PAYMENT">Nursery payment</option>
                                <option value="POOR_PATIENT_DISCOUNT">Poor patient discount</option>
                                <option value="MISCELLANEOUS">Miscellaneous</option>

                            </select>

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">
                                Amount
                            </label>

                            <input type="number" name="amount" class="form-control" placeholder="Enter Amount" required>

                        </div>

                        <div class="col-md-12">

                            <label class="form-label">
                                Description
                            </label>

                            <textarea name="description" class="form-control" rows="4"
                                placeholder="Write expense details..."></textarea>

                        </div>

                        <div class="col-md-12">

                            <button type="submit" class="submit-btn">

                                <i class="fa-solid fa-wallet"></i>

                                Save Expense

                            </button>

                        </div>

                    </div>

                </form>

            </div>

            <!-- RESULT -->

            <div class="section-card">

                <div class="section-title">
                    
                </div>

                <div id="expenseResult"></div>

            </div>

        </div>

    </div>

    <script>

        function getSlipTypeDisplayName(type) {
            if (type === "NORMAL_DELIVERY") return "Miscellaneous";
            if (type === "DNC") return "OBS Case";
            if (type === "C_SECTION") return "Gynaecologist Case";
            if (type === "OPD_EVENING") return "OPD EVENING";
            if (type === "OPD_NIGHT") return "OPD NIGHT";
            if (type === "OPD_DAY") return "OPD DAY";
            if (type === "ENT_OPERATION") return "ENT OPERATION";
            if (type === "ULTRASOUND") return "ULTRASOUND";
            if (type === "ENT") return "ENT";
            return type || "Slip";
        }

        const token =
            localStorage.getItem("token");

        const user =
            JSON.parse(
                localStorage.getItem("user")
            );


        // OPERATOR BLOCK
        if (user.role === "OPERATOR") {

            alert("Access Denied");

            window.location.href = "/dashboard";

        }

        // LOAD ALL EXPENSES
        async function loadExpenses() {

            try {

                const response =
                    await fetch(
                        "/api/expense/all-expenses",
                        {
                            headers: {
                                Authorization:
                                    `Bearer ${token}`
                            }
                        }
                    );

                const result =
                    await response.json();

                const expenses =
                    result.data || [];

                let html = "";

                if (expenses.length === 0) {

                    html = `
                    <div class="alert alert-danger">
                        No Expenses Found
                    </div>
                    `;

                }

                expenses.forEach((expense) => {

                    html += `

                    <div class="expense-card">

                        <div class="expense-title">
                            ${expense.category}
                        </div>

                        <div class="info-grid">

                            <div class="info-box">

                                <div class="info-label">
                                    Amount
                                </div>

                                <div class="info-value">
                                    Rs. ${expense.amount}
                                </div>

                            </div>

                            <div class="info-box">

                                <div class="info-label">
                                    Description
                                </div>

                                <div class="info-value">
                                    ${expense.description || "N/A"}
                                </div>

                            </div>

                            <div class="info-box">

                                <div class="info-label">
                                    Added By
                                </div>

                                <div class="info-value">
                                    ${expense.createdBy?.username || "N/A"}
                                </div>

                            </div>

                            <div class="info-box">

                                <div class="info-label">
                                    Date
                                </div>

                                <div class="info-value">
                                    ${new Date(expense.createdAt).toLocaleString()}
                                </div>

                            </div>

                        </div>

                    </div>

                    `;

                });

                document.getElementById(
                    "expenseResult"
                ).innerHTML = html;

            }

            catch (error) {

                console.log(error);

            }

        }



        // DAILY REPORT
        async function dailyExpenseReport() {

            try {

                const response =
                    await fetch(
                        "/api/expense/daily-expense",
                        {
                            headers: {
                                Authorization:
                                    `Bearer ${token}`
                            }
                        }
                    );

                const result =
                    await response.json();

                const report =
                    result.data || {};

                document.getElementById(
                    "expenseResult"
                ).innerHTML = `

                <div class="expense-card">

                    <div class="expense-title">
                        Daily Expense Report
                    </div>

                    <div class="info-grid">

                        <div class="info-box">

                            <div class="info-label">
                                Total Expense
                            </div>

                            <div class="info-value">
                                Rs. ${report.totalExpense || 0}
                            </div>

                        </div>

                        <div class="info-box">

                            <div class="info-label">
                                Total Entries
                            </div>

                            <div class="info-value">
                                ${report.totalEntries || 0}
                            </div>

                        </div>

                    </div>

                </div>

                `;

            }

            catch (error) {

                console.log(error);

            }

        }



        // MONTHLY REPORT
        async function monthlyExpenseReport() {

            try {

                const response =
                    await fetch(
                        "/api/expense/monthly-expense",
                        {
                            headers: {
                                Authorization:
                                    `Bearer ${token}`
                            }
                        }
                    );

                const result =
                    await response.json();

                const report =
                    result.data || {};

                document.getElementById(
                    "expenseResult"
                ).innerHTML = `

                <div class="expense-card">

                    <div class="expense-title">
                        Monthly Expense Report
                    </div>

                    <div class="info-grid">

                        <div class="info-box">

                            <div class="info-label">
                                Total Expense
                            </div>

                            <div class="info-value">
                                Rs. ${report.totalExpense || 0}
                            </div>

                        </div>

                        <div class="info-box">

                            <div class="info-label">
                                Total Entries
                            </div>

                            <div class="info-value">
                                ${report.totalEntries || 0}
                            </div>

                        </div>

                    </div>

                </div>

                `;

            }

            catch (error) {

                console.log(error);

            }

        }



        // CATEGORY REPORT
        async function categoryExpenseReport() {

            try {

                const response =
                    await fetch(
                        "/api/expense/expense-categories",
                        {
                            headers: {
                                Authorization:
                                    `Bearer ${token}`
                            }
                        }
                    );

                const result =
                    await response.json();

                const categories =
                    result.data || [];

                let html = "";

                categories.forEach((item) => {

                    html += `

                    <div class="expense-card">

                        <div class="expense-title">
                            ${item._id}
                        </div>

                        <div class="info-grid">

                            <div class="info-box">

                                <div class="info-label">
                                    Total Expense
                                </div>

                                <div class="info-value">
                                    Rs. ${item.totalExpense}
                                </div>

                            </div>

                            <div class="info-box">

                                <div class="info-label">
                                    Total Entries
                                </div>

                                <div class="info-value">
                                    ${item.totalEntries}
                                </div>

                            </div>

                        </div>

                    </div>

                    `;

                });

                document.getElementById(
                    "expenseResult"
                ).innerHTML = html;

            }

            catch (error) {

                console.log(error);

            }

        }



        // SALARY REPORT
        async function monthlySalaryExpenseReport() {

            try {

                const response =
                    await fetch(
                        "/api/expense/monthly-salary-expense",
                        {
                            headers: {
                                Authorization:
                                    `Bearer ${token}`
                            }
                        }
                    );

                const result =
                    await response.json();

                const report =
                    result.data || {};

                document.getElementById(
                    "expenseResult"
                ).innerHTML = `

                <div class="expense-card">

                    <div class="expense-title">
                        Salary Expense Report
                    </div>

                    <div class="info-grid">

                        <div class="info-box">

                            <div class="info-label">
                                Total Salary Expense
                            </div>

                            <div class="info-value">
                                Rs. ${report.totalSalaryExpense || 0}
                            </div>

                        </div>

                    </div>

                </div>

                `;

            }

            catch (error) {

                console.log(error);

            }

        }




        // DAILY PROFIT LOSS REPORT
        async function dailyProfitLossReport() {

            try {

                const response =
                    await fetch(
                        "/api/expense/daily-profit-loss-report",
                        {
                            headers: {
                                Authorization:
                                    `Bearer ${token}`
                            }
                        }
                    );

                const result =
                    await response.json();

                const report =
                    result.data || {};



                // EXPENSE TABLE
                let expenseRows = "";

                (report.expenseBreakdown || []).forEach((item) => {

                    expenseRows += `

            <tr>
                <td>${item._id}</td>
                <td>Rs. ${item.totalExpense}</td>
            </tr>

            `;

                });



                // SLIP TABLE
                let slipRows = "";

                (report.slipTypeBreakdown || []).forEach((item) => {

                    slipRows += `

            <tr>
                <td>${getSlipTypeDisplayName(item._id)}</td>
                <td>${item.totalSlips}</td>
                <td>Rs. ${item.totalIncome}</td>
            </tr>

            `;

                });



                document.getElementById(
                    "expenseResult"
                ).innerHTML = `

        <div class="expense-card p-3">

            <div class="text-center mb-3">

                <h2 style="font-weight:700;">
                    MAIDA HOSPITAL
                </h2>

                <h5>
                    Daily Profit & Loss Report
                </h5>

                <h6>
                    Date: ${new Date(report.today).toLocaleDateString()}
                </h6>

            </div>

            <!-- SUMMARY TABLE -->

            <table class="table table-bordered table-sm">

                <tbody>

                    <tr>
                        <th>Total Income</th>
                        <td>Rs. ${report.totalIncome || 0}</td>

                        <th>Total Slips</th>
                        <td>${report.totalSlips || 0}</td>
                    </tr>

                    <tr>
                        <th>Normal Expenses</th>
                        <td>Rs. ${report.normalExpenses || 0}</td>

                        <th>Salary Expenses</th>
                        <td>Rs. ${report.salaryExpenses || 0}</td>
                    </tr>

                    <tr>
                        <th>Total Expenses</th>
                        <td>Rs. ${report.totalExpenses || 0}</td>

                        <th>Status</th>
                        <td>
                            ${report.status || "N/A"}
                        </td>
                    </tr>

                    <tr>
                        <th>Profit / Loss</th>
                        <td colspan="3"
                            style="
                                font-size:20px;
                                font-weight:bold;
                                color:${report.profitOrLoss >= 0 ? 'green' : 'red'};
                            ">
                            Rs. ${report.profitOrLoss || 0}
                        </td>
                    </tr>

                </tbody>

            </table>



            <!-- EXPENSE CATEGORY -->

            <h5 class="mt-4 mb-2">
                Expense Categories
            </h5>

            <table class="table table-bordered table-sm">

                <thead>

                    <tr>
                        <th>Category</th>
                        <th>Total Expense</th>
                    </tr>

                </thead>

                <tbody>

                    ${expenseRows}

                </tbody>

            </table>



            <!-- SLIP TYPES -->

            <h5 class="mt-4 mb-2">
                Slip Types Income
            </h5>

            <table class="table table-bordered table-sm">

                <thead>

                    <tr>
                        <th>Slip Type</th>
                        <th>Total Slips</th>
                        <th>Total Income</th>
                    </tr>

                </thead>

                <tbody>

                    ${slipRows}

                </tbody>

            </table>

        </div>

        `;

            }

            catch (error) {

                console.log(error);

            }

        }




        // PROFIT LOSS REPORT
        async function profitLossReport() {

            try {

                const response =
                    await fetch(
                        "/api/expense/profit-loss-report",
                        {
                            headers: {
                                Authorization:
                                    `Bearer ${token}`
                            }
                        }
                    );

                const result =
                    await response.json();

                const report =
                    result.data || {};



                // EXPENSE TABLE
                let expenseRows = "";

                (report.expenseBreakdown || []).forEach((item) => {

                    expenseRows += `

            <tr>
                <td>${item._id}</td>
                <td>Rs. ${item.totalExpense}</td>
            </tr>

            `;

                });



                // SLIP TABLE
                let slipRows = "";

                (report.slipTypeBreakdown || []).forEach((item) => {

                    slipRows += `

            <tr>
                <td>${getSlipTypeDisplayName(item._id)}</td>
                <td>${item.totalSlips}</td>
                <td>Rs. ${item.totalIncome}</td>
            </tr>

            `;

                });



                document.getElementById(
                    "expenseResult"
                ).innerHTML = `

        <div class="expense-card p-3">

            <div class="text-center mb-3">

                <h2 style="font-weight:700;">
                    MAIDA HOSPITAL
                </h2>

                <h5>
                    Monthly Profit & Loss Report 
                </h5>

            </div>

            <!-- SUMMARY TABLE -->

            <table class="table table-bordered table-sm">

                <tbody>

                    <tr>
                        <th>Total Income</th>
                        <td>Rs. ${report.totalIncome || 0}</td>

                        <th>Total Slips</th>
                        <td>${report.totalSlips || 0}</td>
                    </tr>

                    <tr>
                        <th>Normal Expenses</th>
                        <td>Rs. ${report.normalExpenses || 0}</td>

                        <th>Salary Expenses</th>
                        <td>Rs. ${report.salaryExpenses || 0}</td>
                    </tr>

                    <tr>
                        <th>Total Expenses</th>
                        <td>Rs. ${report.totalExpenses || 0}</td>

                        <th>Status</th>
                        <td>
                            ${report.status || "N/A"}
                        </td>
                    </tr>

                    <tr>
                        <th>Profit / Loss</th>
                        <td colspan="3"
                            style="
                                font-size:20px;
                                font-weight:bold;
                                color:${report.profitOrLoss >= 0 ? 'green' : 'red'};
                            ">
                            Rs. ${report.profitOrLoss || 0}
                        </td>
                    </tr>

                </tbody>

            </table>



            <!-- EXPENSE CATEGORY -->

            <h5 class="mt-4 mb-2">
                Expense Categories
            </h5>

            <table class="table table-bordered table-sm">

                <thead>

                    <tr>
                        <th>Category</th>
                        <th>Total Expense</th>
                    </tr>

                </thead>

                <tbody>

                    ${expenseRows}

                </tbody>

            </table>



            <!-- SLIP TYPES -->

            <h5 class="mt-4 mb-2">
                Slip Types Income
            </h5>

            <table class="table table-bordered table-sm">

                <thead>

                    <tr>
                        <th>Slip Type</th>
                        <th>Total Slips</th>
                        <th>Total Income</th>
                    </tr>

                </thead>

                <tbody>

                    ${slipRows}

                </tbody>

            </table>

        </div>

        `;

            }

            catch (error) {

                console.log(error);

            }

        }



        // CREATE EXPENSE
        document.getElementById(
            "expenseForm"
        ).addEventListener(

            "submit",

            async (e) => {

                e.preventDefault();

                try {

                    const formData =
                        new FormData(e.target);

                    const data =
                        Object.fromEntries(
                            formData.entries()
                        );

                    const response =
                        await fetch(
                            "/api/expense/create-expense",
                            {
                                method: "POST",

                                headers: {

                                    "Content-Type":
                                        "application/json",

                                    Authorization:
                                        `Bearer ${token}`

                                },

                                body:
                                    JSON.stringify(data)

                            }
                        );

                    const result =
                        await response.json();

                    const messageBox =
                        document.getElementById(
                            "messageBox"
                        );

                    if (response.ok) {

                        messageBox.classList.remove(
                            "d-none",
                            "alert-danger"
                        );

                        messageBox.classList.add(
                            "alert-success"
                        );

                        messageBox.innerHTML =
                            "Expense Added Successfully";

                        e.target.reset();

                        loadExpenses();

                    }

                    else {

                        messageBox.classList.remove(
                            "d-none",
                            "alert-success"
                        );

                        messageBox.classList.add(
                            "alert-danger"
                        );

                        messageBox.innerHTML =
                            result.message;

                    }

                }

                catch (error) {

                    console.log(error);

                }

            }

        );



        // INITIAL LOAD
        loadExpenses();

    </script>

</body>

</html>