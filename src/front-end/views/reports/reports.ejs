<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        HMS Reports
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>
        * {

            margin: 0;

            padding: 0;

            box-sizing: border-box;

        }

        body {

            background:
                linear-gradient(rgba(5, 15, 35, 0.94),
                    rgba(5, 15, 35, 0.94)),

                url('https://images.unsplash.com/photo-1516549655169-df83a0774514?q=80&w=1600&auto=format&fit=crop');

            background-size: cover;

            background-position: center;

            background-attachment: fixed;

            min-height: 100vh;

            font-family: "Segoe UI", sans-serif;

            padding: 30px 0;

        }

        .main-card {

            background: rgba(10, 20, 45, 0.82);

            backdrop-filter: blur(16px);

            border-radius: 30px;

            padding: 40px;

            border: 1px solid rgba(255, 255, 255, 0.08);

            box-shadow:
                0 15px 40px rgba(0, 0, 0, 0.45);

            color: white;

        }

        .page-title {

            font-size: 48px;

            font-weight: 700;

            color: white;

            margin-bottom: 0;

        }

        .dashboard-btn {

            background: linear-gradient(135deg, #00c6ff, #0072ff);

            color: white;

            border: none;

            padding: 12px 24px;

            border-radius: 14px;

            text-decoration: none;

            font-weight: 600;

            transition: 0.3s ease;

            box-shadow:
                0 10px 25px rgba(0, 114, 255, 0.35);

        }

        .dashboard-btn:hover {

            transform: translateY(-3px);

            color: white;

        }

        .report-btn {

            border: none;

            width: 100%;

            padding: 16px;

            border-radius: 18px;

            font-size: 15px;

            font-weight: 700;

            transition: 0.3s ease;

            color: white;

            letter-spacing: 0.5px;

        }

        .report-btn:hover {

            transform: translateY(-6px);

            box-shadow:
                0 10px 25px rgba(0, 0, 0, 0.35);

        }

        .btn-red {

            background:
                linear-gradient(135deg,
                    #1e3c72,
                    #294d8b);

        }

        .btn-blue {

            background:
                linear-gradient(135deg,
                    #244c74,
                    #326295);

        }

        .btn-green {

            background:
                linear-gradient(135deg,
                    #1f4068,
                    #2d5d8f);

        }

        .btn-dark-custom {

            background:
                linear-gradient(135deg,
                    #16213e,
                    #23395d);

        }

        .btn-orange {

            background:
                linear-gradient(135deg,
                    #27496d,
                    #3b6ea5);

            color: white;

        }

        .search-area {

            background: rgba(255, 255, 255, 0.05);

            padding: 25px;

            border-radius: 22px;

            margin-top: 40px;

            border: 1px solid rgba(255, 255, 255, 0.06);

        }

        .search-box {

            border-radius: 15px;

            border: 1px solid rgba(255, 255, 255, 0.08);

            padding: 15px;

            background: rgba(255, 255, 255, 0.10);

            color: white;

            font-size: 16px;

        }

        .search-box::placeholder {

            color: #d1d8e6;

        }

        .search-box:focus {

            background: rgba(255, 255, 255, 0.14);

            color: white;

            box-shadow:
                0 0 0 4px rgba(0, 198, 255, 0.15);

            border: 1px solid #00c6ff;

        }

        .report-card {

            background: rgba(255, 255, 255, 0.08);

            border-radius: 25px;

            padding: 30px;

            margin-top: 30px;

            border: 1px solid rgba(255, 255, 255, 0.08);

            backdrop-filter: blur(14px);

        }

        .report-header {

            display: flex;

            justify-content: space-between;

            align-items: center;

            margin-bottom: 25px;

            flex-wrap: wrap;

            gap: 15px;

        }

        .report-title {

            font-size: 28px;

            font-weight: 700;

            color: white;

        }

        .report-badge {

            background: linear-gradient(135deg, #00c6ff, #0072ff);

            padding: 10px 18px;

            border-radius: 30px;

            font-size: 14px;

            font-weight: 600;

        }

        .info-grid {

            display: grid;

            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));

            gap: 20px;

        }

        .info-box {

            background: rgba(255, 255, 255, 0.06);

            border-radius: 18px;

            padding: 20px;

            border: 1px solid rgba(255, 255, 255, 0.06);

        }

        .info-label {

            font-size: 13px;

            color: #aebbd3;

            margin-bottom: 10px;

            text-transform: uppercase;

            letter-spacing: 1px;

        }

        .info-value {

            font-size: 20px;

            font-weight: 700;

            color: white;

            word-break: break-word;

        }

        .slip-card {

            background: rgba(255, 255, 255, 0.06);

            border-radius: 20px;

            padding: 22px;

            margin-top: 20px;

            border-left: 5px solid #00c6ff;

        }

        .slip-title {

            font-size: 20px;

            font-weight: 700;

            margin-bottom: 18px;

        }

        .alert {

            border-radius: 18px;

            padding: 20px;

            font-size: 18px;

            border: none;

        }

        .alert-danger {

            background: rgba(220, 53, 69, 0.18);

            color: #ffd7dc;

        }

        hr {

            border-color: rgba(255, 255, 255, 0.10);

        }

        @media(max-width:768px) {

            .page-title {

                font-size: 34px;

            }

            .main-card {

                padding: 25px;

            }

        }
    </style>

</head>

<body>

    <div class="container">

        <div class="main-card">

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                <h1 class="page-title">
                    Maida Hospital Reports
                </h1>

                <a href="/dashboard" class="dashboard-btn">
                    <i class="fa-solid fa-table-columns"></i>
                    Dashboard
                </a>

            </div>

            <hr>


            <div id="adminReports" style="display:none;">

                <div class="row g-4">

                    <div class="col-md-3">
                        <button class="report-btn btn-blue"
                            onclick="getReport('/api/reports/daily-income','Daily Income')">
                            <i class="fa-solid fa-money-bill-trend-up"></i>
                            Daily Income
                        </button>
                    </div>

                    <div class="col-md-3">
                        <button class="report-btn btn-green"
                            onclick="getReport('/api/reports/monthly-income','Monthly Income')">
                            <i class="fa-solid fa-chart-line"></i>
                            Monthly Income
                        </button>
                    </div>

                    <div class="col-md-3">
                        <button class="report-btn btn-dark-custom"
                            onclick="getReport('/api/reports/daily-slips','Daily Slips')">
                            <i class="fa-solid fa-file-waveform"></i>
                            Daily Slips
                        </button>
                    </div>

                    <div class="col-md-3">
                        <button class="report-btn btn-orange"
                            onclick="getReport('/api/reports/monthly-slips','Monthly Slips')">
                            <i class="fa-solid fa-folder-open"></i>
                            Monthly Slips
                        </button>
                    </div>

                    <div class="col-md-3">
                        <button class="report-btn btn-red"
                            onclick="getReport('/api/reports/daily-patients','Daily Patients')">
                            <i class="fa-solid fa-hospital-user"></i>
                            Daily Patients
                        </button>
                    </div>

                    <div class="col-md-3">
                        <button class="report-btn btn-blue"
                            onclick="getReport('/api/reports/monthly-patients','Monthly Patients')">
                            <i class="fa-solid fa-users"></i>
                            Monthly Patients
                        </button>
                    </div>

                    <div class="col-md-3">
                        <button class="report-btn btn-green"
                            onclick="getReport('/api/reports/daily-slip-types','Daily Slip Types')">
                            <i class="fa-solid fa-layer-group"></i>
                            Daily Slip Types
                        </button>
                    </div>

                    <div class="col-md-3">
                        <button class="report-btn btn-dark-custom"
                            onclick="getReport('/api/reports/monthly-slip-types','Monthly Slip Types')">
                            <i class="fa-solid fa-chart-pie"></i>
                            Monthly Slip Types
                        </button>
                    </div>

                    <div class="col-md-3">
                        <button class="report-btn btn-orange"
                            onclick="getReport('/api/reports/daily-operators','Daily Operators')">
                            <i class="fa-solid fa-user-doctor"></i>
                            Daily Operators
                        </button>
                    </div>

                    <div class="col-md-3">
                        <button class="report-btn btn-red"
                            onclick="getReport('/api/reports/monthly-operators','Monthly Operators')">
                            <i class="fa-solid fa-stethoscope"></i>
                            Monthly Operators
                        </button>
                    </div>

                </div>


                <div class="search-area">

                    <div class="row align-items-center g-3">

                        <div class="col-md-8">

                            <input type="text" id="mrNumber" class="form-control search-box"
                                placeholder="Enter MR Number">

                        </div>

                        <div class="col-md-4">

                            <button class="report-btn btn-dark-custom" onclick="getPatientHistory()">
                                <i class="fa-solid fa-clock-rotate-left"></i>
                                Patient History
                            </button>

                        </div>

                    </div>

                </div>

            </div>


            <div id="accessDenied" class="alert alert-danger" style="display:none;">

                Only ADMIN can access reports.

            </div>


            <div id="reportResult" class="mt-4"></div>

        </div>

    </div>


    <script>

        function getSlipTypeDisplayName(type) {
            if (type === "NORMAL_DELIVERY") return "Miscellaneous";
            if (type === "DNC") return "OBS Case";
            if (type === "C_SECTION") return "Gynaecologist Case";
            if (type === "OPD_EVENING") return "OPD EVENING";
            if (type === "OPD_NIGHT") return "OPD NIGHT";
            if (type === "OPD_DAY") return "OPD DAY";
            if (type === "ENT_OPERATION") return "ENT OPERATION";
            if (type === "ULTRASOUND") return "ULTRASOUND";
            if (type === "ENT") return "ENT";
            return type || "Slip";
        }

        const token =
            localStorage.getItem("token");

        const userData =
            localStorage.getItem("user");

        let user = null;

        try {

            user = JSON.parse(userData);

        } catch (error) {

            console.log("User parse error");
        }


        // CHECK LOGIN
        if (!token || !user) {

            window.location.href = "/";

        }


        // CHECK ADMIN
        if (user && user.role === "ADMIN") {

            document.getElementById(
                "adminReports"
            ).style.display = "block";

        } else {

            document.getElementById(
                "accessDenied"
            ).style.display = "block";

        }



        // REPORT FUNCTION
        async function getReport(url, title) {

            try {

                document.getElementById(
                    "reportResult"
                ).innerHTML = `

            <div class="alert alert-info">
                Loading...
            </div>

        `;

                const response =
                    await fetch(url, {

                        method: "GET",

                        headers: {

                            Authorization:
                                `Bearer ${token}`,

                            "Content-Type":
                                "application/json"

                        }

                    });

                const result =
                    await response.json();

                console.log(result);


                if (!response.ok) {

                    throw new Error(
                        result.message || "API Error"
                    );

                }

                const data =
                    result.data || result;

                let html = `

        <div class="report-card">

            <div class="report-header">

                <div class="report-title">
                    ${title}
                </div>

                <div class="report-badge">
                    Report Generated
                </div>

            </div>

        `;



                // ARRAY REPORTS
                if (Array.isArray(data)) {

                    html += `
                <div class="row g-4">
            `;

                    data.forEach((item) => {

                        html += `

                <div class="col-md-6">

                    <div class="slip-card">

                        <div class="slip-title">

                            ${item.operatorName || getSlipTypeDisplayName(item._id) || "Report"}

                        </div>

                        <div class="info-grid">

                `;


                        Object.keys(item).forEach((key) => {

                            if (
                                key !== "_id" &&
                                key !== "operatorName"
                            ) {

                                html += `

                        <div class="info-box">

                            <div class="info-label">
                                ${key}
                            </div>

                            <div class="info-value">
                                ${item[key]}
                            </div>

                        </div>

                        `;
                            }

                        });


                        html += `

                        </div>

                    </div>

                </div>

                `;

                    });

                    html += `
                </div>
            `;

                }


                // OBJECT REPORTS
                else {

                    html += `
                <div class="info-grid">
            `;

                    Object.keys(data).forEach((key) => {

                        html += `

                <div class="info-box">

                    <div class="info-label">
                        ${key}
                    </div>

                    <div class="info-value">
                        ${data[key]}
                    </div>

                </div>

                `;

                    });

                    html += `
                </div>
            `;
                }

                html += `
            </div>
        `;


                document.getElementById(
                    "reportResult"
                ).innerHTML = html;

            }

            catch (error) {

                console.log(error);

                document.getElementById(
                    "reportResult"
                ).innerHTML = `

        <div class="alert alert-danger">

            ${error.message}

        </div>

        `;

            }

        }




        // PATIENT HISTORY
        async function getPatientHistory() {

            try {

                const mrNumber =
                    document.getElementById(
                        "mrNumber"
                    ).value.trim();

                if (!mrNumber) {

                    alert(
                        "Please enter MR Number"
                    );

                    return;

                }

                document.getElementById(
                    "reportResult"
                ).innerHTML = `

            <div class="alert alert-info">
                Loading Patient History...
            </div>

        `;


                const response =
                    await fetch(

                        `/api/reports/history/${mrNumber}`,

                        {

                            method: "GET",

                            headers: {

                                Authorization:
                                    `Bearer ${token}`,

                                "Content-Type":
                                    "application/json"

                            }

                        }

                    );

                const result =
                    await response.json();

                console.log(result);


                if (!response.ok) {

                    throw new Error(
                        result.message || "Patient not found"
                    );

                }


                if (
                    !result.data ||
                    !result.data.patient
                ) {

                    throw new Error(
                        "No patient history found"
                    );

                }


                const patient =
                    result.data.patient;

                const slips =
                    result.data.slips || [];


                let slipsHtml = "";


                if (slips.length > 0) {

                    slips.forEach((slip) => {

                        slipsHtml += `

                <div class="slip-card">

                    <div class="slip-title">
                        ${getSlipTypeDisplayName(slip.slipType)}
                    </div>

                    <div class="info-grid">

                        <div class="info-box">

                            <div class="info-label">
                                Amount
                            </div>

                            <div class="info-value">
                                Rs. ${slip.amount || 0}
                            </div>

                        </div>

                        <div class="info-box">

                            <div class="info-label">
                                Operator
                            </div>

                            <div class="info-value">
                                ${slip.registeredBy?.username || "N/A"}
                            </div>

                        </div>

                        <div class="info-box">

                            <div class="info-label">
                                Role
                            </div>

                            <div class="info-value">
                                ${slip.registeredBy?.role || "N/A"}
                            </div>

                        </div>

                        <div class="info-box">

                            <div class="info-label">
                                Date
                            </div>

                            <div class="info-value">
                                ${new Date(slip.createdAt).toLocaleString()}
                            </div>

                        </div>

                    </div>

                </div>

                `;

                    });

                } else {

                    slipsHtml = `

                <div class="alert alert-warning mt-4">

                    No Slips Found

                </div>

            `;
                }



                document.getElementById(
                    "reportResult"
                ).innerHTML = `

        <div class="report-card">

            <div class="report-header">

                <div class="report-title">
                    Patient History
                </div>

                <div class="report-badge">
                    ${patient.mrNumber}
                </div>

            </div>

            <div class="info-grid">

                <div class="info-box">

                    <div class="info-label">
                        Patient Name
                    </div>

                    <div class="info-value">
                        ${patient.patientName || "N/A"}
                    </div>

                </div>

                <div class="info-box">

                    <div class="info-label">
                        Guardian
                    </div>

                    <div class="info-value">
                        ${patient.guardianName || "N/A"}
                    </div>

                </div>

                <div class="info-box">

                    <div class="info-label">
                        Phone
                    </div>

                    <div class="info-value">
                        ${patient.phone || "N/A"}
                    </div>

                </div>

                <div class="info-box">

                    <div class="info-label">
                        Gender
                    </div>

                    <div class="info-value">
                        ${patient.gender || "N/A"}
                    </div>

                </div>

            </div>

            ${slipsHtml}

        </div>

        `;

            }

            catch (error) {

                console.log(error);

                document.getElementById(
                    "reportResult"
                ).innerHTML = `

        <div class="alert alert-danger">

            ${error.message}

        </div>

        `;

            }

        }

    </script>

</body>

</html>