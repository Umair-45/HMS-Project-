<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        Maida Hospital Management Software - Login
    </title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Plus Jakarta Sans", sans-serif;
        }

        body {
            min-height: 100vh;
            background: #060c18;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 15px;
            overflow-x: hidden;
            position: relative;
        }

        /* Ambient Glow Blobs */
        .glow-orb-1 {
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(0, 198, 255, 0.12) 0%, rgba(0, 114, 255, 0) 75%);
            top: -150px;
            left: -150px;
            z-index: 0;
            pointer-events: none;
            animation: pulse-glow-1 12s infinite alternate;
        }

        .glow-orb-2 {
            position: absolute;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(0, 242, 254, 0.08) 0%, rgba(79, 172, 254, 0) 75%);
            bottom: -200px;
            right: -200px;
            z-index: 0;
            pointer-events: none;
            animation: pulse-glow-2 15s infinite alternate;
        }

        @keyframes pulse-glow-1 {
            0% { transform: scale(1) translate(0, 0); opacity: 0.7; }
            100% { transform: scale(1.15) translate(30px, 45px); opacity: 1; }
        }

        @keyframes pulse-glow-2 {
            0% { transform: scale(1) translate(0, 0); opacity: 0.8; }
            100% { transform: scale(1.1) translate(-40px, -30px); opacity: 1; }
        }

        .login-wrapper {
            width: 100%;
            max-width: 1100px;
            z-index: 10;
            position: relative;
        }

        .login-card {
            background: rgba(10, 21, 40, 0.65);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border-radius: 28px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.07);
            box-shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
            transition: border-color 0.4s ease, box-shadow 0.4s ease;
        }

        .login-card:hover {
            border-color: rgba(0, 198, 255, 0.22);
            box-shadow: 0 24px 80px rgba(0, 198, 255, 0.12);
        }

        .left-side {
            padding: 75px 55px;
            color: white;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: linear-gradient(145deg, rgba(13, 29, 56, 0.8), rgba(6, 15, 30, 0.9));
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            position: relative;
        }

        .hospital-badge {
            width: 76px;
            height: 76px;
            border-radius: 20px;
            background: linear-gradient(135deg, #00c6ff, #0072ff);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 35px;
            box-shadow: 0 12px 30px rgba(0, 114, 255, 0.35);
            color: white;
        }

        .main-heading {
            font-size: 42px;
            font-weight: 800;
            line-height: 1.25;
            margin-bottom: 18px;
            letter-spacing: -0.5px;
        }

        .main-heading span {
            background: linear-gradient(90deg, #00c6ff, #00f2fe);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: block;
        }

        .description {
            color: rgba(216, 226, 240, 0.75);
            font-size: 15.5px;
            line-height: 1.8;
            margin-bottom: 40px;
            font-weight: 300;
        }

        .feature-box {
            background: rgba(255, 255, 255, 0.02);
            border-radius: 16px;
            padding: 15px 20px;
            margin-bottom: 16px;
            border: 1px solid rgba(255, 255, 255, 0.04);
            display: flex;
            align-items: center;
            gap: 16px;
            transition: all 0.3s ease;
        }

        .feature-box:hover {
            background: rgba(255, 255, 255, 0.05);
            transform: translateX(5px);
            border-color: rgba(0, 198, 255, 0.15);
        }

        .feature-icon-wrapper {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            background: rgba(0, 198, 255, 0.1);
            color: #00c6ff;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .feature-text {
            font-size: 14.5px;
            color: rgba(229, 237, 248, 0.9);
            font-weight: 500;
        }

        .right-side {
            padding: 75px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: transparent;
        }

        .login-title {
            color: white;
            font-size: 34px;
            font-weight: 700;
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }

        .login-subtitle {
            color: rgba(205, 215, 229, 0.65);
            margin-bottom: 35px;
            font-size: 14px;
            font-weight: 400;
        }

        .input-group-custom {
            position: relative;
            margin-bottom: 24px;
        }

        .input-group-custom label {
            display: block;
            color: rgba(255, 255, 255, 0.85);
            font-weight: 500;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .input-wrapper-inner {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255, 255, 255, 0.3);
            transition: color 0.3s ease;
            display: flex;
            align-items: center;
        }

        .form-control-custom {
            width: 100%;
            height: 56px;
            border-radius: 14px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            background: rgba(255, 255, 255, 0.04);
            color: white;
            padding-left: 50px;
            padding-right: 20px;
            font-size: 14.5px;
            transition: all 0.3s ease;
            outline: none;
        }

        .form-control-custom::placeholder {
            color: rgba(255, 255, 255, 0.25);
        }

        .form-control-custom:focus {
            background: rgba(255, 255, 255, 0.07);
            border-color: #00c6ff;
            box-shadow: 0 0 0 4px rgba(0, 198, 255, 0.12);
        }

        .form-control-custom:focus ~ .input-icon {
            color: #00c6ff;
        }

        .login-btn {
            width: 100%;
            height: 56px;
            border: none;
            border-radius: 14px;
            margin-top: 10px;
            font-size: 15.5px;
            font-weight: 700;
            color: white;
            background: linear-gradient(135deg, #00c6ff, #0072ff);
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 10px 25px rgba(0, 114, 255, 0.25);
            cursor: pointer;
            letter-spacing: 0.5px;
        }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(0, 114, 255, 0.35);
            background: linear-gradient(135deg, #00d2fe, #0082ff);
        }

        .login-btn:active {
            transform: translateY(0);
        }

        .alert {
            border-radius: 14px;
            margin-bottom: 25px;
            border: 1px solid rgba(239, 68, 68, 0.25);
            background: rgba(239, 68, 68, 0.1);
            color: #fca5a5;
            padding: 12px 16px;
            font-size: 13.5px;
            font-weight: 500;
        }

        .footer-text {
            margin-top: 30px;
            text-align: center;
            color: rgba(255, 255, 255, 0.35);
            font-size: 13px;
            font-weight: 400;
            letter-spacing: 0.5px;
        }

        @media(max-width:991px) {
            .left-side {
                padding: 60px 40px;
            }
            .right-side {
                padding: 60px 40px;
            }
            .main-heading {
                font-size: 34px;
            }
        }

        @media(max-width:768px) {
            .left-side {
                display: none;
            }
            .right-side {
                padding: 50px 30px;
            }
            .login-title {
                font-size: 30px;
            }
        }
    </style>

</head>

<body>

    <!-- Ambient background glows -->
    <div class="glow-orb-1"></div>
    <div class="glow-orb-2"></div>

    <div class="login-wrapper">

        <div class="login-card">

            <div class="row g-0">

                <!-- LEFT SIDE -->
                <div class="col-lg-7">

                    <div class="left-side">

                        <div class="hospital-badge">
                            <!-- Premium ECG/Pulse wave SVG logo (Not a plus sign) -->
                            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
                            </svg>
                        </div>

                        <h1 class="main-heading">
                            Maida Hospital
                            <span>
                                Management System
                            </span>
                        </h1>

                        <p class="description">
                            Professional Hospital Management Software designed for patient records, reports, slips management, operator control, and secure hospital operations.
                        </p>

                        <div class="feature-box">
                            <div class="feature-icon-wrapper">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                </svg>
                            </div>
                            <div class="feature-text">
                                Secure Patient Management System
                            </div>
                        </div>

                        <div class="feature-box">
                            <div class="feature-icon-wrapper">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="18" y1="20" x2="18" y2="10" />
                                    <line x1="12" y1="20" x2="12" y2="4" />
                                    <line x1="6" y1="20" x2="6" y2="14" />
                                </svg>
                            </div>
                            <div class="feature-text">
                                Advanced Reports & Analytics
                            </div>
                        </div>

                        <div class="feature-box">
                            <div class="feature-icon-wrapper">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="3" width="7" height="9" />
                                    <rect x="14" y="3" width="7" height="5" />
                                    <rect x="14" y="12" width="7" height="9" />
                                    <rect x="3" y="16" width="7" height="5" />
                                </svg>
                            </div>
                            <div class="feature-text">
                                Professional HMS Dashboard Experience
                            </div>
                        </div>

                    </div>

                </div>

                <!-- RIGHT SIDE -->
                <div class="col-lg-5">

                    <div class="right-side">

                        <h2 class="login-title">
                            Welcome Back
                        </h2>

                        <p class="login-subtitle">
                            Login to access hospital dashboard
                        </p>

                        <% if(typeof error !=="undefined" ){ %>

                            <div class="alert alert-danger">
                                <%= error %>
                            </div>

                        <% } %>

                        <form id="loginForm">

                            <div class="input-group-custom">

                                <label>
                                    Username
                                </label>

                                <div class="input-wrapper-inner">
                                    <input type="text" id="username" class="form-control-custom"
                                        placeholder="Enter Username" required>
                                    <div class="input-icon">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                            <circle cx="12" cy="7" r="4" />
                                        </svg>
                                    </div>
                                </div>

                            </div>

                            <div class="input-group-custom">

                                <label>
                                    Password
                                </label>

                                <div class="input-wrapper-inner">
                                    <input type="password" id="password" class="form-control-custom"
                                        placeholder="Enter Password" required>
                                    <div class="input-icon">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                        </svg>
                                    </div>
                                </div>

                            </div>

                            <button type="submit" class="login-btn">
                                Login To Dashboard
                            </button>

                        </form>

                        <div class="footer-text">
                            Secure HMS Portal Access
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script>

        const loginForm =
            document.getElementById(
                "loginForm"
            );

        loginForm.addEventListener(
            "submit",
            async function (e) {

                e.preventDefault();

                const username =
                    document.getElementById(
                        "username"
                    ).value;

                const password =
                    document.getElementById(
                        "password"
                    ).value;

                try {

                    const response =
                        await fetch(
                            "/api/auth/login",
                            {

                                method: "POST",

                                headers: {
                                    "Content-Type":
                                        "application/json",
                                },

                                body: JSON.stringify({
                                    username,
                                    password,
                                }),

                            }
                        );
                    const data =
                        await response.json();

                    if (data.success) {

                        localStorage.setItem(
                            "token",
                            data.data.token
                        );

                        localStorage.setItem(
                            "user",
                            JSON.stringify(
                                data.data.user
                            )
                        );

                        window.location.href =
                            "/dashboard";

                    }

                    else {

                        alert(data.message);

                    }

                }

                catch (error) {

                    alert(
                        "Login Failed"
                    );

                }

            }
        );

    </script>

</body>

</html>