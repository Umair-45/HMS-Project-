<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        Staff Management
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {

            background:
                linear-gradient(rgba(4, 15, 35, 0.92),
                    rgba(4, 15, 35, 0.92)),

                url("https://images.unsplash.com/photo-1587351021759-3e566b6af7cc?q=80&w=2070&auto=format&fit=crop");

            background-size: cover;

            background-position: center;

            background-repeat: no-repeat;

            min-height: 100vh;

            font-family: "Segoe UI", sans-serif;

            padding: 40px 0;

        }

        .main-card {

            background: rgba(10, 20, 45, 0.82);

            backdrop-filter: blur(16px);

            border-radius: 30px;

            padding: 40px;

            border: 1px solid rgba(255, 255, 255, 0.08);

            box-shadow:
                0 15px 40px rgba(0, 0, 0, 0.5);

        }

        .top-bar {

            display: flex;

            justify-content: space-between;

            align-items: center;

            flex-wrap: wrap;

            gap: 20px;

            margin-bottom: 35px;

        }

        .page-title {

            color: white;

            font-size: 42px;

            font-weight: 700;

        }

        .back-btn {

            background: linear-gradient(135deg, #00c6ff, #0072ff);

            border: none;

            padding: 12px 24px;

            border-radius: 12px;

            color: white;

            font-weight: 600;

            text-decoration: none;

        }

        .dashboard-box {

            background: rgba(255, 255, 255, 0.06);

            border-radius: 22px;

            padding: 25px;

            margin-bottom: 30px;

            border: 1px solid rgba(255, 255, 255, 0.06);

        }

        .box-title {

            color: white;

            font-size: 24px;

            font-weight: 700;

            margin-bottom: 20px;

        }

        .form-control,
        .form-select {

            background-color: #2f3b57 !important;

            border: 1px solid rgba(255, 255, 255, 0.08);

            color: white !important;

            height: 52px;

            border-radius: 14px;

        }

        .form-select option {

            background-color: #1b2742;

            color: white;

        }

        .form-control::placeholder {

            color: #cfd8ea;

        }

        .form-select {

            color: #cfd8ea;

        }

        textarea.form-control {

            height: auto;

        }

        .form-control:focus,
        .form-select:focus {

            box-shadow: none;

            border-color: #00c6ff;

            background: rgba(255, 255, 255, 0.12);

            color: white;

        }

        .action-btn {

            border: none;

            padding: 14px;

            width: 100%;

            border-radius: 14px;

            color: white;

            font-weight: 700;

            transition: 0.3s;

        }

        .action-btn:hover {

            transform: translateY(-2px);

        }

        .btn-blue {

            background: linear-gradient(135deg, #00c6ff, #0072ff);

        }

        .btn-green {

            background: linear-gradient(135deg, #00b894, #00cec9);

        }

        .table-box {

            overflow-x: auto;

        }

        table {

            width: 100%;

            color: white;

        }

        table th {

            background: rgba(255, 255, 255, 0.08);

            padding: 15px;

        }

        table td {

            background: rgba(255, 255, 255, 0.04);

            padding: 14px;

        }

        .mini-btn {

            border: none;

            padding: 8px 14px;

            border-radius: 10px;

            color: white;

            font-size: 14px;

            font-weight: 600;

        }

        .paid-btn {

            background: #00b894;

        }

        .print-btn {

            background: #0984e3;

        }

        .status-paid {

            color: #00ffae;

            font-weight: 700;

        }

        .status-pending {

            color: #ffd166;

            font-weight: 700;

        }

        @media(max-width:768px) {

            .page-title {

                font-size: 30px;

            }

            .main-card {

                padding: 20px;

            }

        }
    </style>

</head>

<body>

    <div class="container">

        <div class="main-card">

            <div class="top-bar">

                <h1 class="page-title">
                    Staff Management
                </h1>

                <a href="/dashboard" class="back-btn">

                    <i class="fa-solid fa-arrow-left"></i>
                    Dashboard

                </a>

            </div>



            <!-- ADD NEW STAFF -->

            <div class="dashboard-box">

                <div class="box-title">
                    Add New Staff
                </div>

                <form id="addStaffForm">

                    <div class="row g-3">

                        <div class="col-md-4">

                            <input type="text" name="fullName" class="form-control"
                                placeholder="Full Name" required>

                        </div>

                        <div class="col-md-4">

                            <input type="text" name="designation" class="form-control"
                                placeholder="Designation" required>

                        </div>

                        <div class="col-md-4">

                            <input type="text" name="department" class="form-control"
                                placeholder="Department" required>

                        </div>

                        <div class="col-md-4">

                            <input type="number" name="basicSalary" class="form-control"
                                placeholder="Basic Salary (Rs.)" required>

                        </div>

                        <div class="col-md-4">

                            <input type="text" name="phone" class="form-control"
                                placeholder="Phone Number">

                        </div>

                        <div class="col-md-4">

                            <input type="text" name="address" class="form-control"
                                placeholder="Address">

                        </div>

                        <div class="col-md-12">

                            <button class="action-btn btn-blue" type="submit">

                                Add Staff Member

                            </button>

                        </div>

                    </div>

                </form>

            </div>



            <!-- ADD ALLOWANCE -->

            <div class="dashboard-box">

                <div class="box-title">
                    Add Daily Allowance
                </div>

                <form id="allowanceForm">

                    <div class="row g-3">

                        <div class="col-md-4">

                            <select name="staffId" class="form-select" id="staffSelect" required>

                                <option value="">
                                    Select Staff
                                </option>

                            </select>

                        </div>

                        <div class="col-md-4">

                            <select name="allowanceType" class="form-select" id="allowanceType" required>

                            </select>

                        </div>

                        <div class="col-md-4">

                            <input type="number" name="amount" class="form-control"
                                placeholder="Allowance Amount" required>

                        </div>

                        <div class="col-md-6">

                            <input type="number" name="month" class="form-control" placeholder="Month" required>

                        </div>

                        <div class="col-md-6">

                            <input type="number" name="year" class="form-control" placeholder="Year" required>

                        </div>

                        <div class="col-md-12">

                            <textarea name="notes" class="form-control" rows="3"
                                placeholder="Allowance Notes"></textarea>

                        </div>

                        <div class="col-md-12">

                            <button class="action-btn btn-green" type="submit">

                                Add Allowance

                            </button>

                        </div>

                    </div>

                </form>

            </div>





            <!-- GENERATE PAYROLL -->

            <div class="dashboard-box">

                <div class="box-title">
                    Generate Monthly Payroll
                </div>

                <form id="payrollForm">

                    <div class="row g-3">

                        <div class="col-md-3">

                            <select name="staffId" class="form-select" id="payrollStaffSelect" required>

                                <option value="">
                                    Select Staff
                                </option>

                            </select>

                        </div>

                        <div class="col-md-3">

                            <input type="number" name="month" class="form-control" placeholder="Month" required>

                        </div>

                        <div class="col-md-3">

                            <input type="number" name="year" class="form-control" placeholder="Year" required>

                        </div>

                        <div class="col-md-3">

                            <input type="number" name="deduction" class="form-control" placeholder="Deduction (Rs.)" min="0" value="0">

                        </div>

                        <div class="col-md-12">

                            <button type="submit" class="action-btn btn-blue">

                                Generate Payroll

                            </button>

                        </div>

                    </div>

                </form>

            </div>





            <!-- STAFF TABLE -->

            <div class="dashboard-box">

                <div class="box-title">
                    All Staff
                </div>

                <div class="table-box">

                    <table class="table">

                        <thead>

                            <tr>

                                <th>Name</th>

                                <th>Designation</th>

                                <th>Department</th>

                                <th>Salary</th>

                                <th>Phone</th>

                                <th>Actions</th>

                            </tr>

                        </thead>

                        <tbody id="staffTableBody">

                        </tbody>

                    </table>

                </div>

            </div>





            <!-- PAYROLL TABLE -->

            <div class="dashboard-box">

                <div class="box-title">
                    Payroll Records
                </div>

                <div class="d-flex justify-content-end mb-3">

                    <button class="mini-btn print-btn" onclick="printAllStaffSalaryReport()">

                        Print Staff Salary Report

                    </button>

                </div>

                <div class="table-box">

                    <table class="table">

                        <thead>

                            <tr>

                                <th>Staff</th>

                                <th>Month</th>

                                <th>Basic Salary</th>

                                <th>Allowance</th>

                                <th>Deduction</th>

                                <th>Net Salary</th>

                                <th>Status</th>

                                <th>Actions</th>

                            </tr>

                        </thead>

                        <tbody id="payrollTableBody">

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>


    <script>

          const user =
        JSON.parse(
            localStorage.getItem("user")
        );

    // OPERATOR BLOCK
    if (user && user.role === "OPERATOR") {

        window.location.href = "/dashboard";

    }

    const token =
        localStorage.getItem("token");

        // ==============================
        // ALLOWANCE TYPES
        // ==============================

        const allowanceTypes = [

            "BONUS",
            "OVERTIME",
            "TRANSPORT",
            "FOOD",
            "MEDICAL",
            "NIGHT_DUTY",
            "EMERGENCY",
            "ATTENDANCE",
            "OTHER"

        ];



        const allowanceSelect =
            document.getElementById(
                "allowanceType"
            );



        allowanceSelect.innerHTML =

            `<option value="">
            Select Allowance Type
        </option>`;


        allowanceTypes.forEach((type) => {

            allowanceSelect.innerHTML += `

        <option value="${type}">
            ${type}
        </option>

        `;

        });





        // ==============================
        // GET ALL STAFF
        // ==============================

        async function getAllStaff() {

            try {

                const response = await fetch(

                    "/api/staff/all-staff",

                    {

                        method: "GET",

                        headers: {

                            Authorization:
                                `Bearer ${token}`

                        }

                    }

                );



                const result =
                    await response.json();

                if (!result.success) {

                    alert(result.message);

                    return;

                }



                const staff =
                    result.data || [];



                const tbody =
                    document.getElementById(
                        "staffTableBody"
                    );

                tbody.innerHTML = "";



                const allowanceSelect =
                    document.getElementById(
                        "staffSelect"
                    );

                allowanceSelect.innerHTML =

                    `<option value="">
                    Select Staff
                </option>`;


                const payrollSelect =
                    document.getElementById(
                        "payrollStaffSelect"
                    );

                payrollSelect.innerHTML =

                    `<option value="">
                    Select Staff
                </option>`;



                staff.forEach((item) => {

                    tbody.innerHTML += `

                <tr>

                    <td>
                        ${item.fullName}
                    </td>

                    <td>
                        ${item.designation}
                    </td>

                    <td>
                        ${item.department}
                    </td>

                    <td>
                        Rs ${item.basicSalary}
                    </td>

                    <td>
                        ${item.phone || "-"}
                    </td>

                    <td>
                        <button class="mini-btn" style="background: #ef4444;" onclick="deleteStaff('${item._id}')">
                            Delete
                        </button>
                    </td>

                </tr>

                `;



                    allowanceSelect.innerHTML += `

                <option value="${item._id}">
                    ${item.fullName}
                </option>

                `;



                    payrollSelect.innerHTML += `

                <option value="${item._id}">
                    ${item.fullName}
                </option>

                `;

                });

            }

            catch (error) {

                console.log(error);

            }

        }







        // ==============================
        // ADD NEW STAFF
        // ==============================

        document.getElementById(
            "addStaffForm"
        )

            .addEventListener(

                "submit",

                async function (e) {

                    e.preventDefault();

                    const formData =
                        new FormData(this);

                    const data =
                        Object.fromEntries(formData);

                    const response =
                        await fetch(

                            "/api/staff/create-staff",

                            {

                                method: "POST",

                                headers: {

                                    "Content-Type":
                                        "application/json",

                                    Authorization:
                                        `Bearer ${token}`

                                },

                                body:
                                    JSON.stringify(data)

                            }

                        );

                    const result =
                        await response.json();

                    alert(result.message);

                    if (result.success) {

                        getAllStaff();

                        this.reset();

                    }

                }

            );







        // ==============================
        // ADD ALLOWANCE
        // ==============================

        document.getElementById(
            "allowanceForm"
        )

            .addEventListener(

                "submit",

                async function (e) {

                    e.preventDefault();

                    const formData =
                        new FormData(this);

                    const data =
                        Object.fromEntries(formData);

                    const response =
                        await fetch(

                            "/api/staff/add-allowance",

                            {

                                method: "POST",

                                headers: {

                                    "Content-Type":
                                        "application/json",

                                    Authorization:
                                        `Bearer ${token}`

                                },

                                body:
                                    JSON.stringify(data)

                            }

                        );

                    const result =
                        await response.json();

                    alert(result.message);

                    this.reset();

                }

            );









        // ==============================
        // GENERATE PAYROLL
        // ==============================

        document.getElementById(
            "payrollForm"
        )

            .addEventListener(

                "submit",

                async function (e) {

                    e.preventDefault();

                    const formData =
                        new FormData(this);

                    const data =
                        Object.fromEntries(formData);

                    const response =
                        await fetch(

                            "/api/staff/generate-payroll",

                            {

                                method: "POST",

                                headers: {

                                    "Content-Type":
                                        "application/json",

                                    Authorization:
                                        `Bearer ${token}`

                                },

                                body:
                                    JSON.stringify(data)

                            }

                        );

                    const result =
                        await response.json();

                    alert(result.message);

                    getPayrolls();

                    this.reset();

                }

            );









        // ==============================
        // GET PAYROLLS
        // ==============================

        async function getPayrolls() {

            try {

                const response = await fetch(

                    "/api/staff/all-payrolls",

                    {

                        method: "GET",

                        headers: {

                            Authorization:
                                `Bearer ${token}`

                        }

                    }

                );



                const result =
                    await response.json();

                if (!result.success) {

                    alert(result.message);

                    return;

                }



                const payrolls =
                    result.data || [];



                const tbody =
                    document.getElementById(
                        "payrollTableBody"
                    );



                tbody.innerHTML = "";



                payrolls.forEach((item) => {

                    tbody.innerHTML += `

                <tr>

                    <td>
                        ${item.staffId?.fullName || "-"}
                    </td>

                    <td>
                        ${item.month}/${item.year}
                    </td>

                    <td>
                        Rs ${item.basicSalary}
                    </td>

                    <td>
                        Rs ${item.totalAllowance || 0}
                    </td>

                    <td>
                        Rs ${item.totalDeduction || 0}
                    </td>

                    <td>
                        Rs ${item.netSalary}
                    </td>

                    <td>

                        ${item.paymentStatus === "PAID"

                            ?

                            `<span class="status-paid">
                            PAID
                        </span>`

                            :

                            `<span class="status-pending">
                            PENDING
                        </span>`

                        }

                    </td>

                    <td>

                        ${item.paymentStatus === "PENDING"

                            ?

                            `<button
                            class="mini-btn paid-btn"
                            onclick="markPaid('${item._id}')">

                            Mark Paid

                        </button>`

                            :

                            `
                        <button
                            class="mini-btn print-btn"
                            onclick='printSlip(${JSON.stringify(item)})'>

                            Print Slip

                        </button>
                        `
                        }

                    </td>

                </tr>

                `;

                });

            }

            catch (error) {

                console.log(error);

            }

        }









        // ==============================
        // MARK SALARY PAID
        // ==============================

        async function markPaid(id) {

            const response =
                await fetch(

                    `/api/staff/mark-paid/${id}`,

                    {

                        method: "PATCH",

                        headers: {

                            Authorization:
                                `Bearer ${token}`

                        }

                    }

                );

            const result =
                await response.json();

            alert(result.message);

            getPayrolls();

        }



        async function deleteStaff(id) {

            if (!confirm("Are you sure you want to delete this staff member?")) {

                return;

            }

            try {

                const response = await fetch(

                    `/api/staff/delete-staff/${id}`,

                    {

                        method: "DELETE",

                        headers: {

                            Authorization:
                                `Bearer ${token}`

                        }

                    }

                );

                const result =
                    await response.json();

                alert(result.message);

                if (result.success) {

                    getAllStaff();

                    getPayrolls();

                }

            }

            catch (error) {

                console.log(error);

            }

        }









        // ==============================
        // PRINT SINGLE SLIP
        // ==============================

        function printSlip(item) {

            const printWindow =
                window.open(
                    "",
                    "",
                    "width=1000,height=700"
                );

            printWindow.document.write(`

        <html>

        <head>

            <title>
                Monthly Salary Slip
            </title>

            <style>

                body{
                    font-family: Arial;
                    padding:40px;
                    color:#222;
                }

                .top{
                    text-align:center;
                    margin-bottom:30px;
                }

                .top h1{
                    margin:0;
                    font-size:34px;
                }

                .top p{
                    margin:5px 0;
                    color:#555;
                }

                .slip-title{
                    background:#0d6efd;
                    color:white;
                    padding:12px;
                    text-align:center;
                    font-size:22px;
                    margin-bottom:30px;
                }

                table{
                    width:100%;
                    border-collapse:collapse;
                }

                table th,
                table td{
                    border:1px solid #999;
                    padding:14px;
                    text-align:left;
                }

                table th{
                    background:#f1f1f1;
                    width:35%;
                }

                .footer{
                    margin-top:60px;
                    display:flex;
                    justify-content:space-between;
                }

            </style>

        </head>

        <body>

            <div class="top">

                <h1>
                    MAIDA HOSPITAL
                </h1>

                <p>
                    Hospital Management System
                </p>

                <p>
                    China Center Abbottabad
                </p>

            </div>

            <div class="slip-title">

                MONTHLY SALARY SLIP

            </div>

            <table>

                <tr>

                    <th>Employee Name</th>

                    <td>
                        ${item.staffId?.fullName || "-"}
                    </td>

                </tr>

                <tr>

                    <th>Designation</th>

                    <td>
                        ${item.staffId?.designation || "-"}
                    </td>

                </tr>

                <tr>

                    <th>Department</th>

                    <td>
                        ${item.staffId?.department || "-"}
                    </td>

                </tr>

                <tr>

                    <th>Salary Month</th>

                    <td>
                        ${item.month}/${item.year}
                    </td>

                </tr>

                <tr>

                    <th>Basic Salary</th>

                    <td>
                        Rs. ${item.basicSalary}
                    </td>

                </tr>

                <tr>

                    <th>Total Allowance</th>

                    <td>
                        Rs. ${item.totalAllowance}
                    </td>

                </tr>

                <tr>

                    <th>Total Deduction</th>

                    <td>
                        Rs. ${item.totalDeduction}
                    </td>

                </tr>

                <tr>

                    <th>Net Salary</th>

                    <td>
                        <strong>
                            Rs. ${item.netSalary}
                        </strong>
                    </td>

                </tr>

                <tr>

                    <th>Payment Status</th>

                    <td>
                        ${item.paymentStatus}
                    </td>

                </tr>

                <tr>

                    <th>Generated Date</th>

                    <td>
                        ${new Date(item.createdAt).toLocaleDateString()}
                    </td>

                </tr>

            </table>

            <div class="footer">

                <div>

                    ______________________

                    <br><br>

                    Accountant Signature

                </div>

                <div>

                    ______________________

                    <br><br>

                    Employee Signature

                </div>

            </div>

        </body>

        </html>

        `);

            printWindow.document.close();

            printWindow.print();

        }








        // ==============================
        // PRINT ALL STAFF SALARY REPORT
        // ==============================

        function printAllStaffSalaryReport() {

            const rows =
                document.querySelectorAll(
                    "#payrollTableBody tr"
                );

            let tableRows = "";

            let totalBasic = 0;
            let totalAllowance = 0;
            let totalDeduction = 0;
            let totalNet = 0;

            rows.forEach((row) => {

                const cols = row.querySelectorAll("td");

                if (cols.length > 0) {

                    const staffName =
                        cols[0].innerText;

                    const month =
                        cols[1].innerText;

                    const basicSalary =
                        Number(
                            cols[2]
                                .innerText
                                .replace("Rs", "")
                                .trim()
                        );

                    const allowance =
                        Number(
                            cols[3]
                                .innerText
                                .replace("Rs", "")
                                .trim()
                        );

                    const deduction =
                        Number(
                            cols[4]
                                .innerText
                                .replace("Rs", "")
                                .trim()
                        );

                    const netSalary =
                        Number(
                            cols[5]
                                .innerText
                                .replace("Rs", "")
                                .trim()
                        );

                    const status =
                        cols[6].innerText;

                    totalBasic += basicSalary;
                    totalAllowance += allowance;
                    totalDeduction += deduction;
                    totalNet += netSalary;

                    tableRows += `

                    <tr>

                        <td>${staffName}</td>

                        <td>${month}</td>

                        <td>Rs. ${basicSalary}</td>

                        <td>Rs. ${allowance}</td>

                        <td>Rs. ${deduction}</td>

                        <td>Rs. ${netSalary}</td>

                        <td>${status}</td>

                    </tr>

                    `;
                }

            });

            const printWindow =
                window.open(
                    "",
                    "",
                    "width=1200,height=800"
                );

            printWindow.document.write(`

            <html>

            <head>

                <title>
                    Staff Salary Report
                </title>

                <style>

                    body{
                        font-family: Arial;
                        padding:30px;
                        color:#222;
                    }

                    .top{
                        text-align:center;
                        margin-bottom:30px;
                    }

                    .top h1{
                        margin:0;
                        font-size:38px;
                    }

                    .top h3{
                        margin-top:10px;
                        color:#444;
                    }

                    table{
                        width:100%;
                        border-collapse:collapse;
                        margin-top:20px;
                    }

                    table th,
                    table td{
                        border:1px solid #999;
