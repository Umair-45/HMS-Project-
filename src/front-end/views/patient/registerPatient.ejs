<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        Register Patient
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>
        * {

            margin: 0;

            padding: 0;

            box-sizing: border-box;

        }

        body {

            background:
                linear-gradient(rgba(5, 15, 35, 0.92),
                    rgba(5, 15, 35, 0.92)),

                url('https://images.unsplash.com/photo-1586773860418-d37222d8fce3?q=80&w=1600&auto=format&fit=crop');

            background-size: cover;

            background-position: center;

            background-attachment: fixed;

            min-height: 100vh;

            font-family: "Segoe UI", sans-serif;

            padding: 30px 0;

        }

        .main-card {

            background: rgba(10, 20, 45, 0.82);

            backdrop-filter: blur(16px);

            border-radius: 30px;

            padding: 45px;

            margin-top: 20px;

            margin-bottom: 20px;

            border: 1px solid rgba(255, 255, 255, 0.08);

            box-shadow:
                0 15px 40px rgba(0, 0, 0, 0.45);

            color: white;

        }

        .top-bar {

            display: flex;

            justify-content: space-between;

            align-items: center;

            margin-bottom: 35px;

            flex-wrap: wrap;

            gap: 20px;

        }

        .page-title {

            font-size: 48px;

            font-weight: 700;

            margin-bottom: 10px;

            color: #ffffff;

            letter-spacing: 1px;

        }

        .sub-title {

            color: #b8c7e0;

            font-size: 18px;

            margin-bottom: 0;

        }

        .dashboard-btn {

            text-decoration: none;

            background: linear-gradient(135deg, #00c6ff, #0072ff);

            color: white;

            padding: 12px 24px;

            border-radius: 14px;

            font-weight: 600;

            transition: 0.3s ease;

            box-shadow:
                0 8px 20px rgba(0, 114, 255, 0.35);

        }

        .dashboard-btn:hover {

            transform: translateY(-3px);

            color: white;

        }

        .form-box {

            background: rgba(255, 255, 255, 0.04);

            border-radius: 24px;

            padding: 30px;

            border: 1px solid rgba(255, 255, 255, 0.06);

        }

        .form-label {

            font-weight: 600;

            margin-bottom: 10px;

            color: #dfe9ff;

            font-size: 15px;

        }

        .form-control,
        .form-select {

            border-radius: 14px;

            padding: 14px 16px;

            border: 1px solid rgba(255, 255, 255, 0.08);

            background: rgba(255, 255, 255, 0.12);

            color: white;

            font-size: 15px;

            transition: 0.3s ease;

        }

        .form-control::placeholder {

            color: #d0d8e8;

        }

        .form-select option {

            color: black;

        }

        .form-control:focus,
        .form-select:focus {

            background: rgba(255, 255, 255, 0.16);

            color: white;

            border: 1px solid #00c6ff;

            box-shadow:
                0 0 0 4px rgba(0, 198, 255, 0.15);

        }

        textarea.form-control {

            resize: none;

        }

        .register-btn {

            width: 100%;

            background: linear-gradient(135deg, #00c6ff, #0072ff);

            border: none;

            padding: 15px;

            font-size: 18px;

            border-radius: 16px;

            color: white;

            font-weight: 700;

            transition: 0.3s ease;

            margin-top: 10px;

            box-shadow:
                0 10px 25px rgba(0, 114, 255, 0.35);

        }

        .register-btn:hover {

            transform: translateY(-4px);

        }

        .alert {

            border-radius: 18px;

            font-size: 17px;

            border: none;

            padding: 25px;

            margin-bottom: 25px;

        }

        .alert-success {

            background: rgba(25, 135, 84, 0.2);

            color: #b8ffcf;

            border-left: 5px solid #198754;

        }

        .alert-danger {

            background: rgba(220, 53, 69, 0.18);

            color: #ffd5da;

            border-left: 5px solid #dc3545;

        }

        .input-icon {

            position: relative;

        }

        .input-icon i {

            position: absolute;

            top: 50%;

            left: 16px;

            transform: translateY(-50%);

            color: #c7d4ec;

            font-size: 15px;

        }

        .input-icon .form-control,
        .input-icon .form-select {

            padding-left: 45px;

        }

        @media(max-width:768px) {

            .page-title {

                font-size: 34px;

            }

            .main-card {

                padding: 25px;

            }

            .top-bar {

                flex-direction: column;

                align-items: flex-start;

            }

        }
    </style>

</head>

<body>

    <div class="container">

        <div class="main-card">

            <div class="top-bar">

                <div>

                    <h1 class="page-title">
                        Maida Hospital Abbottabad
                    </h1>

                    <p class="sub-title">
                        Smart Patient Registration System
                    </p>

                </div>

                <a href="/dashboard" class="dashboard-btn">
                    <i class="fa-solid fa-table-columns"></i>
                    Dashboard
                </a>

            </div>


            <div id="messageBox" class="alert d-none"></div>


            <div class="form-box">

                <form id="patientForm">

                    <div class="row">

                        <!-- Patient Name -->
                        <div class="col-md-6 mb-4">

                            <label class="form-label">
                                Patient Name
                            </label>

                            <div class="input-icon">

                                <i class="fa-solid fa-user"></i>

                                <input type="text" name="patientName" class="form-control"
                                    placeholder="Enter patient name" required>

                            </div>

                        </div>

                        <!-- Guardian Name -->
                        <div class="col-md-6 mb-4">

                            <label class="form-label">
                                Guardian Name
                            </label>

                            <div class="input-icon">

                                <i class="fa-solid fa-users"></i>

                                <input type="text" name="guardianName" class="form-control"
                                    placeholder="Enter guardian name">

                            </div>

                        </div>

                        <!-- Guardian Relation -->
                        <div class="col-md-6 mb-4">

                            <label class="form-label">
                                Guardian Relation
                            </label>

                            <div class="input-icon">

                                <i class="fa-solid fa-people-arrows"></i>

                                <select name="guardianRelation" class="form-select">

                                    <option value="HUSBAND">
                                        Husband
                                    </option>

                                    <option value="FATHER">
                                        Father
                                    </option>

                                    <option value="MOTHER">
                                        Mother
                                    </option>

                                    <option value="BROTHER">
                                        Brother
                                    </option>

                                    <option value="OTHER">
                                        Other
                                    </option>

                                </select>

                            </div>

                        </div>

                        <!-- Age -->
                        <div class="col-md-6 mb-4">

                            <label class="form-label">
                                Age
                            </label>

                            <div class="input-icon">

                                <i class="fa-solid fa-calendar"></i>

                                <input type="number" name="age" class="form-control" placeholder="Enter age">

                            </div>

                        </div>

                        <!-- Gender -->
                        <div class="col-md-6 mb-4">

                            <label class="form-label">
                                Gender
                            </label>

                            <div class="input-icon">

                                <i class="fa-solid fa-venus-mars"></i>

                                <select name="gender" class="form-select">

                                    <option value="MALE">
                                        Male
                                    </option>

                                    <option value="FEMALE">
                                        Female
                                    </option>

                                    <option value="OTHER">
                                        Other
                                    </option>

                                </select>

                            </div>

                        </div>

                        <!-- Phone -->
                        <div class="col-md-6 mb-4">

                            <label class="form-label">
                                Phone
                            </label>

                            <div class="input-icon">

                                <i class="fa-solid fa-phone"></i>

                                <input type="text" name="phone" class="form-control" placeholder="Enter phone number">

                            </div>

                        </div>

                        <!-- Address -->
                        <div class="col-md-12 mb-4">

                            <label class="form-label">
                                Address
                            </label>

                            <div class="input-icon">

                                <i class="fa-solid fa-location-dot"></i>

                                <textarea name="address" class="form-control" rows="4"
                                    placeholder="Enter complete address"></textarea>

                            </div>

                        </div>

                    </div>

                    <button type="submit" class="register-btn">

                        <i class="fa-solid fa-user-check"></i>

                        Register Patient

                    </button>

                </form>

            </div>

        </div>

    </div>


    <script>

        const form =
            document.getElementById(
                "patientForm"
            );

        const messageBox =
            document.getElementById(
                "messageBox"
            );

        form.addEventListener(
            "submit",

            async (e) => {

                e.preventDefault();

                try {

                    const formData =
                        new FormData(form);

                    const data =
                        Object.fromEntries(
                            formData.entries()
                        );

                    const token =
                        localStorage.getItem(
                            "token"
                        );

                    const response =
                        await fetch(
                            "/api/patient/register",
                            {
                                method: "POST",

                                headers: {

                                    "Content-Type":
                                        "application/json",

                                    Authorization:
                                        `Bearer ${token}`,

                                },

                                body:
                                    JSON.stringify(
                                        data
                                    ),

                            }
                        );

                    const result =
                        await response.json();

                    // SUCCESS
                    if (result.success) {

                        messageBox.classList.remove(
                            "d-none",
                            "alert-danger"
                        );

                        messageBox.classList.add(
                            "alert-success"
                        );

                        messageBox.innerHTML = `

                        <div style="
                            font-size:26px;
                            font-weight:bold;
                            margin-bottom:15px;
                        ">
                            Patient Registered Successfully
                        </div>

                        <hr>

                        <div style="
                            font-size:20px;
                            margin-bottom:12px;
                        ">

                            <strong>
                                MR Number :
                            </strong>

                            ${result.data.mrNumber}

                        </div>

                        <div style="
                            font-size:20px;
                        ">

                            <strong>
                                Patient Name :
                            </strong>

                            ${result.data.patientName}

                        </div>

                    `;

                        form.reset();

                    }

                    // ERROR
                    // ERROR
                    else {

                        messageBox.classList.remove(
                            "d-none",
                            "alert-success"
                        );

                        messageBox.classList.add(
                            "alert-danger"
                        );

                        // Duplicate Patient
                        if (result.existingPatient) {

                            messageBox.innerHTML = `

        <div style="
            font-size:24px;
            font-weight:bold;
            margin-bottom:15px;
        ">
            Patient Already Registered
        </div>

        <hr>

        <div style="
            font-size:18px;
            margin-bottom:10px;
        ">
            <strong>MR Number :</strong>
            ${result.existingPatient.mrNumber}
        </div>

        <div style="
            font-size:18px;
            margin-bottom:10px;
        ">
            <strong>Name :</strong>
            ${result.existingPatient.patientName}
        </div>

        <div style="
            font-size:18px;
        ">
            <strong>Phone :</strong>
            ${result.existingPatient.phone || "N/A"}
        </div>

        `;

                        }

                        else {

                            messageBox.innerHTML =
                                result.message;

                        }

                    }

                }

                catch (error) {

                    console.log(error);

                    messageBox.classList.remove(
                        "d-none",
                        "alert-success"
                    );

                    messageBox.classList.add(
                        "alert-danger"
                    );

                    messageBox.innerText =
                        "Patient not found or server error";

                }

            }

        );

    </script>

</body>

</html>