            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div style="font-size: 13px; line-height: 1.5; color: #000;">
                    <div style="font-weight: bold; color: #0b1831; font-size: 15px; margin-bottom: 4px; letter-spacing: 0.5px;">FBR FISCALIZED INVOICE</div>
                    <div>POS ID: <strong id="printFbrPosId"><%= typeof fbrPosId !== 'undefined' ? fbrPosId : '194518' %></strong></div>
                    <div>FBR Invoice Number: <strong id="printFbrInvoiceNumber" style="font-family: monospace; font-size: 14px;"></strong></div>
                </div>
                <div style="text-align: right;">
                    <img id="printFbrQrCode" src="" style="width: 70px; height: 70px; display: none;" alt="FBR QR Code" />
                </div>
            </div>
        </div>

    </div>


    <script>

        const subOptionsData = {
            NORMAL_DELIVERY: [
                { label: "Appendectomy" },
                { label: "Cholecystectomy" },
                { label: "Hemorrhoidectomy" },
                { label: "IUCD Placement" },
                { label: "IUCD Removal" },
                { label: "Incision & Drainage" }
            ],
            DNC: [
                { label: "NVD With Episiotomy" },
                { label: "Twins Vaginal Delivery" },
                { label: "Vaccum Assisted Delivery" },
                { label: "Spontaneous Expulsion F/B -  E&C" },
                { label: "Incomplete Miscarriage F/B - E&C" },
                { label: "Breech Delivery" },
                { label: "D&C" },
                { label: "Elective - C-Section" },
                { label: "Emergency - C-Section" }
            ],
            C_SECTION: [
                { label: "Laprotomy" },
                { label: "TAH & BSO" },
                { label: "TAH" },
                { label: "V.H" },
                { label: "VH & AP Repair" },
                { label: "AP Repair" },
                { label: "Cervical Cerclage" },
                { label: "Bartholin Cyst" },
                { label: "Cystectomy" }
            ],
            ENT_OPERATION: [
                { label: "Nasal polypectomy" },
                { label: "Aural polypectomy" },
                { label: "Adeno tonsilectomy" },
                { label: "Cautry nasal" },
                { label: "Myringoplasty local" },
                { label: "D/L" },
                { label: "Rigid endoscopy" },
                { label: "Myringotomy" },
                { label: "Myringotomy with groments" },
                { label: "OTO Endoscopy" },
                { label: "tonsilectomy" },
                { label: "Myringoplasty GA" },
                { label: "septoplasty" }
            ],
            ENT: [
                { label: "Nasal polypectomy" },
                { label: "Aural polypectomy" },
                { label: "Adeno tonsilectomy" },
                { label: "Cautry nasal" },
                { label: "Myringoplasty local" },
                { label: "D/L" },
                { label: "Rigid endoscopy" },
                { label: "Myringotomy" },
                { label: "Myringotomy with groments" },
                { label: "OTO Endoscopy" },
                { label: "tonsilectomy" },
                { label: "Myringoplasty GA" },
                { label: "septoplasty" }
            ]
        };

        const form =
            document.getElementById(
                "createSlipForm"
            );

        const slipTypeSelect = document.querySelector('select[name="slipType"]');
        const amountInput = document.querySelector('input[name="amount"]');
        const subOptionsContainer = document.getElementById("subOptionsContainer");
        const subOptionsLabel = document.getElementById("subOptionsLabel");
        const subOptionsSelect = document.getElementById("subOptionsSelect");

        function updateSubOptions() {
            const selectedType = slipTypeSelect.value;
            if (subOptionsData[selectedType]) {
                let categoryLabel = "Sub-Options";
                if (selectedType === "NORMAL_DELIVERY") categoryLabel = "Miscellaneous Options";
                else if (selectedType === "DNC") categoryLabel = "OBS Case Options";
                else if (selectedType === "C_SECTION") categoryLabel = "Gynaecologist Case Options";
                else if (selectedType === "ENT_OPERATION" || selectedType === "ENT") categoryLabel = "ENT Options";

                subOptionsLabel.innerText = categoryLabel;
                
                subOptionsSelect.innerHTML = '<option value="">-- Select Option --</option>';
                subOptionsData[selectedType].forEach(opt => {
                    const optionEl = document.createElement("option");
                    optionEl.value = opt.label;
                    optionEl.innerText = opt.display || opt.label;
                    if (opt.price !== undefined) {
                        optionEl.setAttribute("data-price", opt.price);
                    }
                    subOptionsSelect.appendChild(optionEl);
                });
                
                subOptionsContainer.style.display = "block";
                subOptionsSelect.required = true;
            } else {
                subOptionsContainer.style.display = "none";
                subOptionsSelect.innerHTML = "";
                subOptionsSelect.required = false;
            }
        }

        slipTypeSelect.addEventListener("change", () => {
            updateSubOptions();
            amountInput.value = "";
        });

        subOptionsSelect.addEventListener("change", () => {
            const selectedOpt = subOptionsSelect.options[subOptionsSelect.selectedIndex];
            if (selectedOpt && selectedOpt.value) {
                const price = selectedOpt.getAttribute("data-price");
                amountInput.value = price || "";
            } else {
                amountInput.value = "";
            }
        });

        let savedSlip = null;


        // CREATE SLIP
        form.addEventListener(
            "submit",
            async (e) => {

                e.preventDefault();

                const formData =
                    new FormData(form);

                const data = {

                    mrNumber:
                        formData.get(
                            "mrNumber"
                        ),

                    slipType:
                        formData.get(
                            "slipType"
                        ),

                    doctorName:
                        formData.get(
                            "doctorName"
                        ),

                    amount:
                        Number(
                            formData.get(
                                "amount"
                            )
                        ),

                    paymentStatus:
                        formData.get(
                            "paymentStatus"
                        ),

                    selectedOption:
                        formData.get(
                            "selectedOption"
                        ) || "",

                };

                try {

                    const response =
                        await fetch(
                            "/api/slip/createSlip",
                            {

                                method: "POST",

                                headers: {

                                    "Content-Type":
                                        "application/json",

                                    Authorization:
                                        `Bearer ${localStorage.getItem("token")}`,

                                },

                                body:
                                    JSON.stringify(
                                        data
                                    ),

                            }
                        );

                    const result =
                        await response.json();

                    if (
                        result.success
                    ) {

                        savedSlip =
                            result.data;

                        alert(
                            "Slip Created Successfully"
                        );

                        document.getElementById(
                            "printSlip"
                        ).style.display =
                            "block";

                        // FBR Details
                        const fbrContainer = document.getElementById("fbrSectionContainer");
                        const fbrInvNumEl = document.getElementById("printFbrInvoiceNumber");
                        const fbrQrCodeEl = document.getElementById("printFbrQrCode");

                        if (savedSlip.fbrInvoiceNumber) {
                            document.getElementById("printSlip").classList.add("has-fbr");
                            fbrContainer.style.display = "block";
                            fbrInvNumEl.innerText = savedSlip.fbrInvoiceNumber;
                            // Generate QR code pointing to FBR verification page
                            const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=https://ims.fbr.gov.pk/fbr-verification/verification?in=${savedSlip.fbrInvoiceNumber}`;
                            fbrQrCodeEl.src = qrUrl;
                            fbrQrCodeEl.style.display = "block";
                        } else {
                            document.getElementById("printSlip").classList.remove("has-fbr");
                            fbrContainer.style.display = "none";
                            fbrInvNumEl.innerText = "";
                            fbrQrCodeEl.src = "";
                            fbrQrCodeEl.style.display = "none";
                        }

                        // PATIENT NAME
                        document.getElementById(
                            "printPatientName"
                        ).innerText =
                            savedSlip.patientName ||
                            savedSlip.patient?.patientName ||
                            "";

                        // ADDRESS FROM BACKEND
                        document.getElementById(
                            "printAddress"
                        ).innerText =
                            savedSlip.patient?.address ||
                            savedSlip.address ||
                            "N/A";

                        // SLIP TYPE
                        const slipTypeVal = savedSlip.slipType || "";
                        let displaySlipType = slipTypeVal;
                        if (slipTypeVal === "OPD_EVENING") {
                            displaySlipType = "OPD EVENING";
                        } else if (slipTypeVal === "OPD_NIGHT") {
                            displaySlipType = "OPD NIGHT";
                        } else if (slipTypeVal === "OPD_DAY") {
                            displaySlipType = "OPD DAY";
                        } else if (slipTypeVal === "NORMAL_DELIVERY") {
                            displaySlipType = "Miscellaneous";
                        } else if (slipTypeVal === "ENT_OPERATION") {
                            displaySlipType = "ENT OPERATION";
                        } else if (slipTypeVal === "C_SECTION") {
                            displaySlipType = "Gynaecologist - Case";
                        } else if (slipTypeVal === "ULTRASOUND") {
                            displaySlipType = "ULTRASOUND";
                        } else if (slipTypeVal === "ENT") {
                            displaySlipType = "ENT";
                        } else if (slipTypeVal === "DNC") {
                            displaySlipType = "OBS - Case";
                        }

                        document.getElementById(
                            "printSlipType"
                        ).innerText = displaySlipType;

                        const eveningNightTypeEl = document.getElementById("printSlipTypeEveningNight");
                        if (eveningNightTypeEl) {
                            eveningNightTypeEl.innerText = displaySlipType;
                        }

                        const ultrasoundTypeEl = document.getElementById("printSlipTypeUltrasound");
                        if (ultrasoundTypeEl) {
                            ultrasoundTypeEl.innerText = displaySlipType;
                        }

                        const entTypeEl = document.getElementById("printSlipTypeEnt");
                        if (entTypeEl) {
                            entTypeEl.innerText = displaySlipType;
                        }

                        // Toggle dynamic styling classes
                        const printSlipEl = document.getElementById("printSlip");
                        printSlipEl.classList.remove("evening-night-mode", "ultrasound-mode", "ent-mode", "ent-operation-mode", "c-section-mode", "normal-delivery-mode", "lab-mode", "dnc-mode", "hijama-mode");

                        if (slipTypeVal === "OPD_EVENING" || slipTypeVal === "OPD_NIGHT") {
                            printSlipEl.classList.add("evening-night-mode");
                        } else if (slipTypeVal === "ULTRASOUND") {
                            printSlipEl.classList.add("ultrasound-mode");
                        } else if (slipTypeVal === "ENT") {
                            printSlipEl.classList.add("ent-mode");
                        } else if (slipTypeVal === "ENT_OPERATION") {
                            printSlipEl.classList.add("ent-operation-mode");
                        } else if (slipTypeVal === "C_SECTION") {
                            printSlipEl.classList.add("c-section-mode");
                        } else if (slipTypeVal === "NORMAL_DELIVERY") {
                            printSlipEl.classList.add("normal-delivery-mode");
                        } else if (slipTypeVal === "LAB") {
                            printSlipEl.classList.add("lab-mode");
                        } else if (slipTypeVal === "DNC") {
                            printSlipEl.classList.add("dnc-mode");
                        } else if (slipTypeVal === "HIJAMA") {
                            printSlipEl.classList.add("hijama-mode");
                        }

                        // Populate ENT_OPERATION fields if applicable
                        if (slipTypeVal === "ENT_OPERATION") {
                            const patName = savedSlip.patientName || savedSlip.patient?.patientName || "";
                            const guardName = savedSlip.patient?.guardianName || "N/A";
                            const slipDate = new Date().toLocaleDateString();
                            const docName = savedSlip.doctorName || data.doctorName;
                            const addr = savedSlip.patient?.address || savedSlip.address || "N/A";
                            const phoneVal = savedSlip.patient?.phone || "N/A";

                            document.getElementById("printDateEntOp").innerText = slipDate;
                            document.getElementById("printDoctorEntOp").innerText = docName;
                            document.getElementById("printAddressEntOp").innerText = addr;
                            document.getElementById("printPhoneEntOp").innerText = phoneVal;
                            document.getElementById("printPatientNameEntOp").innerText = patName;
                            document.getElementById("printGuardianNameEntOp").innerText = guardName;

                            const selectedOpt = savedSlip.selectedOption || "";
                            const labelEl = document.getElementById("printEntOperationTitleLabel");
                            if (labelEl) {
                                labelEl.innerText = selectedOpt ? `ENT Operation - ${selectedOpt}` : "ENT Operation";
                            }
                        }

                        // Populate C_SECTION fields if applicable
                        if (slipTypeVal === "C_SECTION") {
                            const patName = savedSlip.patientName || savedSlip.patient?.patientName || "";
                            const guardName = savedSlip.patient?.guardianName || "N/A";
                            const slipDate = new Date().toLocaleDateString();
                            const docName = savedSlip.doctorName || data.doctorName;
                            const addr = savedSlip.patient?.address || savedSlip.address || "N/A";
                            const phoneVal = savedSlip.patient?.phone || "N/A";

                            document.getElementById("printDateCsec").innerText = slipDate;
                            document.getElementById("printDoctorCsec").innerText = docName;
                            document.getElementById("printAddressCsec").innerText = addr;
                            document.getElementById("printPhone1Csec").innerText = phoneVal;
                            document.getElementById("printPatientNameCsec").innerText = patName;
                            document.getElementById("printGuardianNameCsec").innerText = guardName;

                            const selectedOpt = savedSlip.selectedOption || "";
                            const labelEl = document.getElementById("printCSectionTitleLabel");
                            if (labelEl) {
                                labelEl.innerText = selectedOpt ? `Gynaecologist - Case - ${selectedOpt}` : "Gynaecologist - Case";
                            }
                        }

                        // Populate NORMAL_DELIVERY fields if applicable
                        if (slipTypeVal === "NORMAL_DELIVERY") {
                            const patName = savedSlip.patientName || savedSlip.patient?.patientName || "";
                            const guardName = savedSlip.patient?.guardianName || "N/A";
                            const guardRelation = savedSlip.patient?.guardianRelation || "N/A";
                            const slipDate = new Date().toLocaleDateString();
                            const addr = savedSlip.patient?.address || savedSlip.address || "N/A";
                            const phoneVal = savedSlip.patient?.phone || "N/A";

                            document.getElementById("printPatientNameNorm").innerText = patName;
                            document.getElementById("printGuardianNameNorm").innerText = guardName;
                            document.getElementById("printAddressNorm").innerText = addr;
                            document.getElementById("printDateNorm").innerText = slipDate;
                            document.getElementById("printGuardianNameFieldNorm").innerText = guardName;
                            document.getElementById("printGuardianRelationNorm").innerText = guardRelation;
                            document.getElementById("printPhone1Norm").innerText = phoneVal;

                            const selectedOpt = savedSlip.selectedOption || "";
                            const labelEl = document.getElementById("printNormalDeliveryTitleLabel");
                            if (labelEl) {
                                labelEl.innerText = selectedOpt ? `Miscellaneous - ${selectedOpt}` : "Miscellaneous";
                            }
                        }

                        // Populate DNC fields if applicable
                        if (slipTypeVal === "DNC") {
                            const patName = savedSlip.patientName || savedSlip.patient?.patientName || "";
                            const guardName = savedSlip.patient?.guardianName || "N/A";
                            const slipDate = new Date().toLocaleDateString();

                            document.getElementById("printDateDnc").innerText = slipDate;
                            document.getElementById("printPatientNameDnc").innerText = patName;
                            document.getElementById("printGuardianNameDnc").innerText = guardName;
                            document.getElementById("printPatientNameSigDnc").innerText = patName;
                            document.getElementById("printGuardianNameSigDnc").innerText = guardName;
                            document.getElementById("printPatientNameUrduDnc").innerText = patName;
                            document.getElementById("printGuardianNameUrduDnc").innerText = guardName;
                            document.getElementById("printPatientUrduSigDnc").innerText = patName;
                            document.getElementById("printGuardianUrduSigDnc").innerText = guardName;
                            document.getElementById("printDateUrduDnc").innerText = slipDate;

                            const selectedOpt = savedSlip.selectedOption || "";
                            const labelEl = document.getElementById("printDncTitleLabel");
                            if (labelEl) {
                                labelEl.innerText = selectedOpt ? `OBS - Case - ${selectedOpt}` : "OBS - Case";
                            }
                        }

                        // Populate HIJAMA fields if applicable
                        if (slipTypeVal === "HIJAMA") {
                            const patName = savedSlip.patientName || savedSlip.patient?.patientName || "";
                            const mrNo = savedSlip.mrNumber || savedSlip.patient?.mrNumber || data.mrNumber;
                            const addr = savedSlip.patient?.address || savedSlip.address || "N/A";
                            const age = savedSlip.patient?.age || "";
                            const gender = savedSlip.patient?.gender || "";
                            const slipDate = new Date().toLocaleDateString();

                            document.getElementById("printPatientNameHij").innerText = patName;
                            document.getElementById("printMrHij").innerText = mrNo;
                            document.getElementById("printAddressHij").innerText = addr;
                            document.getElementById("printAgeHij").innerText = age;
                            document.getElementById("printGenderHij").innerText = gender;

                            // Set Date 1
                            document.getElementById("printDate1Hij").innerText = slipDate;
                        }

                        // Populate LAB patient fields if applicable
                        if (slipTypeVal === "LAB") {
                            const patName = savedSlip.patientName || savedSlip.patient?.patientName || "";
                            const mrNo = savedSlip.mrNumber || savedSlip.patient?.mrNumber || data.mrNumber;
                            const slipDate = new Date().toLocaleDateString();
                            const docName = savedSlip.doctorName || data.doctorName;
                            const addr = savedSlip.patient?.address || savedSlip.address || "N/A";
                            const payStatus = savedSlip.paymentStatus || data.paymentStatus;
                            const amt = savedSlip.amount || data.amount;

                            document.getElementById("printPatientNameLab").innerText = patName;
                            document.getElementById("printMrLab").innerText = mrNo;
                            document.getElementById("printDateLab").innerText = slipDate;
                            document.getElementById("printDoctorLab").innerText = docName;
                            document.getElementById("printAddressLab").innerText = addr;
                            document.getElementById("printAmountPaymentLab").innerText = `Rs. ${amt} / ${payStatus}`;
                        }

                        // DATE
                        document.getElementById(
                            "printDate"
                        ).innerText =
                            new Date().toLocaleDateString();

                        // MR NUMBER
                        document.getElementById(
                            "printMr"
                        ).innerText =
                            savedSlip.mrNumber ||
                            savedSlip.patient?.mrNumber ||
                            data.mrNumber;

                        // DOCTOR
                        document.getElementById(
                            "printDoctor"
                        ).innerText =
                            savedSlip.doctorName ||
                            data.doctorName;

                        // PAYMENT STATUS FROM BACKEND
                        document.getElementById(
                            "printPayment"
                        ).innerText =
                            savedSlip.paymentStatus ||
                            data.paymentStatus;

                        // AMOUNT
                        document.getElementById(
                            "printAmount"
                        ).innerText =
                            savedSlip.amount ||
                            data.amount;

                    }

                    else {

                        alert(
                            result.message
                        );

                    }

                }

                catch (error) {

                    console.log(error);

                    alert(
                        "Something went wrong"
                    );

                }

            });


        // PRINT
        function printSlip() {

            if (!savedSlip) {

                alert(
                    "Please create slip first"
                );

                return;

            }

            window.print();

        }

        // FBR Diagnostic Status Check
        async function checkFbrStatus() {
            const fbrDot = document.getElementById("fbrStatusDot");
            const fbrText = document.getElementById("fbrStatusText");
            const fbrTrouble = document.getElementById("fbrTroubleshoot");
            const btnCheck = document.getElementById("btnCheckFbr");
            const btnText = document.getElementById("fbrBtnText");

            if (!fbrDot || !fbrText || !fbrTrouble || !btnCheck || !btnText) return;

            // Show checking status
            fbrDot.className = "fbr-status-dot checking";
            fbrText.innerText = "Checking Connection...";
            fbrText.style.color = "#f59e0b";
            btnCheck.disabled = true;
            btnText.innerText = "Checking...";

            try {
                const response = await fetch("/api/slip/check-fbr", {
                    headers: {
                        Authorization: `Bearer ${localStorage.getItem("token")}`
                    }
                });
                const result = await response.json();

                if (result.success && result.status === "online") {
                    fbrDot.className = "fbr-status-dot online";
                    fbrText.innerText = "Online (Ready)";
                    fbrText.style.color = "#10b981";
                    fbrTrouble.style.display = "none";
                } else {
                    fbrDot.className = "fbr-status-dot offline";
                    fbrText.innerText = "Offline (Not Running)";
                    fbrText.style.color = "#ef4444";
                    fbrTrouble.style.display = "block";
                }
            } catch (err) {
                fbrDot.className = "fbr-status-dot offline";
                fbrText.innerText = "Offline (Error)";
                fbrText.style.color = "#ef4444";
                fbrTrouble.style.display = "block";
            } finally {
                btnCheck.disabled = false;
                btnText.innerText = "Check Status";
            }
        }

        // Run connection check on page load and attach to button
        setTimeout(checkFbrStatus, 500);
        document.getElementById("btnCheckFbr").addEventListener("click", checkFbrStatus);

    </script>

</body>

</html>