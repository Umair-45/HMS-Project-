            font-weight: bold;
            text-align: center;
            padding: 3px 12px;
            border-radius: 15px;
            margin-bottom: 6px;
            display: inline-block;
            min-width: 140px;
            text-transform: uppercase;
        }

        /* Test Lines styling */
        .lab-item {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 3px;
            font-size: 11px;
            line-height: 1.2;
        }

        .lab-item-name {
            font-weight: bold;
            color: #222;
            white-space: nowrap;
        }

        .lab-item-dots {
            flex-grow: 1;
            border-bottom: 1px dotted #aaa;
            margin-bottom: 2px;
            margin-left: 5px;
            margin-right: 5px;
        }

        .lab-item-val-unit {
            display: flex;
            justify-content: space-between;
            width: 130px;
            /* standard width for value space + unit/range */
            font-size: 10px;
            font-weight: normal;
        }

        .lab-item-val {
            color: #666;
        }

        .lab-item-range {
            text-align: right;
            color: #444;
            font-weight: bold;
            white-space: pre-wrap;
            /* allow newline for range if needed */
        }

        /* Sub items (indented) */
        .lab-sub-item {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 2px;
            margin-left: 15px;
            font-size: 10.5px;
            line-height: 1.2;
        }

        .lab-sub-item-name {
            color: #444;
            white-space: nowrap;
        }

        .lab-sub-item-dots {
            flex-grow: 1;
            border-bottom: 1px dotted #bbb;
            margin-bottom: 2px;
            margin-left: 5px;
            margin-right: 5px;
        }

        .lab-sub-item-val-unit {
            display: flex;
            justify-content: space-between;
            width: 130px;
            font-size: 10px;
        }

        /* ICT TB Specific */
        .lab-ict-title {
            font-weight: bold;
            font-size: 12px;
            color: #b10000;
            margin-top: 6px;
            margin-bottom: 4px;
            text-decoration: underline;
        }

        /* Urine Analysis Section Grid */
        .lab-urine-section {
            border-top: 1px solid #ccc;
            padding-top: 8px;
            margin-top: 8px;
        }

        .lab-urine-header-container {
            text-align: center;
            margin-bottom: 6px;
        }

        .lab-urine-header {
            background-color: #f3705a;
            color: white;
            font-size: 12px;
            font-weight: bold;
            padding: 3px 20px;
            border-radius: 15px;
            display: inline-block;
            text-transform: uppercase;
        }

        .lab-urine-cols {
            display: flex;
            justify-content: space-between;
            gap: 15px;
        }

        .lab-urine-col {
            width: 32%;
        }

        .lab-urine-sub-header {
            font-weight: bold;
            font-size: 11px;
            text-decoration: underline;
            color: #222;
            margin-bottom: 4px;
            text-align: center;
            text-transform: uppercase;
        }

        .lab-urine-item {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 3px;
            font-size: 10px;
        }

        .lab-urine-item-name {
            font-weight: bold;
            color: #333;
            white-space: nowrap;
        }

        .lab-urine-item-dots {
            flex-grow: 1;
            border-bottom: 1px dotted #ccc;
            margin-bottom: 2px;
            margin-left: 4px;
            margin-right: 4px;
        }

        .lab-urine-item-val {
            color: #555;
            min-width: 35px;
            text-align: right;
            white-space: nowrap;
        }

        .lab-pregnancy-test {
            font-size: 11px;
            font-weight: bold;
            margin-top: 6px;
            display: flex;
            align-items: flex-end;
        }

        /* Footer styling */
        .lab-footer {
            display: none;
            width: 100%;
            position: absolute;
            bottom: 12mm;
            left: 12mm;
            right: 12mm;
            justify-content: space-between;
            align-items: flex-end;
            border-top: 1px solid #ccc;
            padding-top: 6px;
        }

        .lab-footer-left {
            font-size: 11px;
            font-weight: bold;
            color: #666;
            line-height: 1.3;
        }

        .lab-footer-right {
            font-size: 6px;
            font-weight: bold;
            color: #333;
            border-top: 1px solid #333;
            width: 180px;
            text-align: center;
            padding-top: 4px;
        }

        /* Toggle Classes */
        .slip-preview.lab-mode .slip-header,
        .slip-preview.lab-mode .evening-night-header,
        .slip-preview.lab-mode .evening-night-footer,
        .slip-preview.lab-mode .ultrasound-header,
        .slip-preview.lab-mode .ultrasound-body,
        .slip-preview.lab-mode .ent-header,
        .slip-preview.lab-mode .ent-footer,
        .slip-preview.lab-mode .rx-area,
        .slip-preview.lab-mode .patient-info {
            display: none !important;
        }

        .slip-preview.lab-mode .lab-header {
            display: flex !important;
        }

        .slip-preview.lab-mode .lab-patient-info {
            display: block !important;
        }

        .slip-preview.lab-mode .lab-body {
            display: block !important;
        }

        .slip-preview.lab-mode .lab-footer {
            display: flex !important;
        }

        /* FBR Status Widget Styles */
        .fbr-status-widget {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 14px 18px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
            transition: all 0.3s ease;
        }

        .fbr-status-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .fbr-status-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background-color: #f59e0b;
            box-shadow: 0 0 8px #f59e0b;
            transition: all 0.3s ease;
        }

        .fbr-status-dot.online {
            background-color: #10b981;
            box-shadow: 0 0 10px #10b981;
            animation: pulse-green 2s infinite;
        }

        .fbr-status-dot.offline {
            background-color: #ef4444;
            box-shadow: 0 0 10px #ef4444;
        }

        .fbr-status-dot.checking {
            background-color: #f59e0b;
            box-shadow: 0 0 10px #f59e0b;
            animation: pulse-yellow 1.5s infinite;
        }

        @keyframes pulse-green {
            0% { transform: scale(1); box-shadow: 0 0 8px #10b981; }
            50% { transform: scale(1.15); box-shadow: 0 0 14px #10b981; }
            100% { transform: scale(1); box-shadow: 0 0 8px #10b981; }
        }

        @keyframes pulse-yellow {
            0% { transform: scale(1); box-shadow: 0 0 8px #f59e0b; }
            50% { transform: scale(1.15); box-shadow: 0 0 14px #f59e0b; }
            100% { transform: scale(1); box-shadow: 0 0 8px #f59e0b; }
        }

        .fbr-status-text {
            font-size: 14px;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.9);
        }

        .fbr-status-val {
            font-weight: 600;
        }

        .btn-check-fbr {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 8px;
            color: #fff;
            padding: 6px 12px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .btn-check-fbr:hover {
            background: rgba(255, 255, 255, 0.15);
            border-color: rgba(255, 255, 255, 0.25);
        }

        .fbr-troubleshoot {
            display: none;
            background: rgba(239, 68, 68, 0.08);
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 24px;
            color: #fca5a5;
            font-size: 13px;
            line-height: 1.6;
            animation: fadeIn 0.4s ease;
        }

        .fbr-troubleshoot h4 {
            color: #ef4444;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .fbr-troubleshoot ol {
            padding-left: 18px;
            margin-top: 6px;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-5px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>


</head>

