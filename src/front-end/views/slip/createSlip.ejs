<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        Create Slip
    </title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <!-- Google Fonts for Urdu Nastaliq -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Nastaliq+Urdu:wght@400..700&display=swap"
        rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {

            background:
                linear-gradient(rgba(8, 20, 45, 0.92),
                    rgba(8, 20, 45, 0.92)),

                url("https://images.unsplash.com/photo-1586773860418-d37222d8fce3?q=80&w=2070&auto=format&fit=crop");

            background-size: cover;

            background-position: center;

            min-height: 100vh;

            font-family: Arial, sans-serif;

            padding: 40px 0;

        }

        .main-card {

            background: rgba(255, 255, 255, 0.08);

            backdrop-filter: blur(14px);

            border-radius: 25px;

            overflow: hidden;

            border: 1px solid rgba(255, 255, 255, 0.08);

            box-shadow:
                0 15px 40px rgba(0, 0, 0, 0.4);

        }

        .header-box {

            background:
                rgb(11, 24, 49);

            padding: 35px;

            text-align: center;

            color: white;

        }

        .hospital-logo {

            width: 90px;

            height: 90px;

            border-radius: 50%;

            background: white;

            color: #b10000;

            display: flex;

            align-items: center;

            justify-content: center;

            font-size: 34px;

            font-weight: bold;

            margin: auto;

            margin-bottom: 18px;

        }

        .hospital-title {

            font-size: 42px;

            font-weight: bold;

        }

        .hospital-subtitle {

            font-size: 18px;

            margin-top: 8px;

        }

        .form-section {

            padding: 35px;

            color: white;

        }

        .form-label {

            font-weight: bold;

            margin-bottom: 10px;

        }

        .form-control,
        .form-select {

            height: 55px;

            border-radius: 12px;

            border: none;

            background: rgba(255, 255, 255, 0.12);

            color: white;

        }

        .form-control::placeholder {

            color: #ddd;

        }

        .form-control:focus,
        .form-select:focus {

            background: rgba(255, 255, 255, 0.18);

            color: white;

            box-shadow:
                0 0 0 4px rgba(255, 255, 255, 0.08);

        }

        option {

            color: black;

        }

        .btn-custom {

            height: 55px;

            border-radius: 12px;

            border: none;

            font-size: 18px;

            font-weight: bold;

        }

        .create-btn {

            background: #15803d;

            color: white;

        }

        .print-btn {

            background: #2563eb;

            color: white;

        }

        .slip-preview {

            width: 210mm;

            height: 297mm;

            background: white;

            margin: 40px auto;

            padding: 12mm;

            color: black;

            display: none;

            overflow: hidden;

            position: relative;

        }

        .slip-header {

            display: flex;

            justify-content: space-between;

            align-items: flex-start;

        }

        .doctor-left {

            width: 30%;

            color: #233d84;

        }

        .doctor-right {

            width: 30%;

            color: #233d84;

            direction: rtl;

            text-align: right;

        }

        .doctor-main {

            font-size: 15px;

            font-weight: bold;

            line-height: 1.4;

        }

        .doctor-sub {

            font-size: 15px;

            margin-top: 4px;

            line-height: 1.5;

        }

        .hospital-center {

            width: 35%;

            text-align: center;

        }

        .urdu-title {

            color: #b10000;

            font-size: 42px;

            font-weight: bold;

            margin-bottom: 4px;

        }

        .hospital-small {

            font-size: 15px;

            font-weight: bold;

        }

        .middle-note {

            border: 2px solid #777;

            border-radius: 12px;

            padding: 10px;

            margin-top: 12px;

            font-size: 12px;

            line-height: 1.7;

        }

        .emergency {

            color: #b10000;

            font-size: 24px;

            font-weight: bold;

            margin-top: 10px;

        }

        .slip-type {

            background: #b10000;

            color: white;

            padding: 8px 18px;

            border-radius: 30px;

            display: inline-block;

            margin-top: 10px;

            font-weight: bold;

            font-size: 16px;

        }

        .patient-info {

            margin-top: 16px;

            border-top: 1px solid #555;

            padding-top: 10px;

            font-size: 15px;

            font-weight: bold;

        }

        .patient-row {

            display: flex;

            justify-content: space-between;

            margin-bottom: 12px;

            gap: 10px;

        }

        .field {

            border-bottom: 1px dotted #555;

            min-width: 160px;

            display: inline-block;

            padding-left: 8px;

        }

        .rx-area {

            display: flex;

            margin-top: 8px;

            border-top: 1px solid #555;

            height: 880px;

        }

        .rx-left {

            width: 73%;

            padding: 14px;

            position: relative;

        }

        .rx-right {

            width: 27%;

            border-left: 2px solid #666;

            padding: 14px;

            position: relative;

        }

        .rx-symbol {

            font-size: 60px;

            color: #233d84;

            font-family: cursive;

            margin-bottom: 25px;

        }

        .medicine-space {

            height: 760px;

        }

        .clinical-title {

            text-align: center;

            font-size: 22px;

            color: #233d84;

            font-weight: bold;

            margin-bottom: 25px;

        }

        .clinical-item {

            font-size: 22px;

            color: #233d84;

            font-weight: bold;

            margin-bottom: 28px;

        }

        .investigation {

            position: absolute;

            bottom: 35px;

            left: 25px;

            font-size: 18px;

            font-weight: bold;

            color: #233d84;

        }

        @media print {

            html, body {
                height: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
                overflow: hidden !important;
                page-break-after: avoid !important;
                page-break-before: avoid !important;
            }

            @page {

                size: A4;

                margin: 0;

            }

            body {

                background: white;

                margin: 0;

                padding: 0;

            }

            body * {

                visibility: hidden;

            }

            #printSlip,
            #printSlip * {

                visibility: visible;

            }

            #printSlip {

                position: absolute !important;

                left: 0 !important;

                top: 0 !important;

                width: 210mm !important;

                height: 297mm !important;

                max-height: 297mm !important;

                margin: 0 !important;

                padding: 12mm !important;

                overflow: hidden !important;

                box-sizing: border-box !important;

                page-break-after: avoid !important;

                page-break-before: avoid !important;

                page-break-inside: avoid !important;

                break-inside: avoid !important;

            }

        }

        /* Noto Nastaliq Urdu styling */
        .urdu-nastaliq {
            font-family: 'Noto Nastaliq Urdu', serif;
        }

        /* Evening & Night Premium Header and Footer Styles */
        .evening-night-header {
            display: none;
            width: 100%;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #1c3d5a;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }

        .evening-night-logo-container {
            width: 100px;
            height: 100px;
        }

        .evening-night-title-container {
            flex-grow: 1;
            text-align: center;
        }

        .evening-night-urdu-title {
            color: #b10000;
            font-size: 38px;
            font-weight: bold;
            line-height: 1.6;
        }

        .evening-night-urdu-specialties {
            color: #1c3d5a;
            font-size: 14px;
            font-weight: bold;
            margin-top: 5px;
            direction: rtl;
        }

        .evening-night-slip-type-container {
            margin-top: 8px;
            text-align: center;
        }

        .evening-night-date-container {
            width: 150px;
            text-align: right;
            font-size: 16px;
            color: #333;
            direction: rtl;
        }

        .evening-night-date-line {
            border-bottom: 1px solid #333;
            width: 100px;
            display: inline-block;
            vertical-align: middle;
        }

        .evening-night-footer {
            display: none;
            position: absolute;
            bottom: 15mm;
            left: 12mm;
            right: 12mm;
            border-top: 2px solid #1c3d5a;
            padding-top: 10px;
            justify-content: space-between;
            align-items: center;
        }

        .evening-night-footer-left {
            color: #1c3d5a;
            font-size: 15px;
            font-weight: bold;
            font-family: 'Noto Nastaliq Urdu', Arial, sans-serif;
        }

        .evening-night-footer-right {
            color: #b10000;
            font-size: 22px;
            font-weight: bold;
            font-family: 'Noto Nastaliq Urdu', serif;
        }

        /* Toggle between templates based on evening-night-mode class */
        .slip-preview.evening-night-mode .slip-header {
            display: none !important;
        }

        .slip-preview.evening-night-mode .evening-night-header {
            display: flex !important;
        }

        .slip-preview.evening-night-mode .evening-night-footer {
            display: flex !important;
        }

        /* Adjust Rx area height in evening-night-mode to accommodate footer */
        .slip-preview.evening-night-mode .rx-area {
            height: 750px !important;
        }

        .slip-preview.evening-night-mode .medicine-space {
            height: 630px !important;
        }

        /* FBR Section Layout Adjustments */
        .fbr-section-container {
            position: absolute;
            bottom: 10mm;
            left: 12mm;
            right: 12mm;
            height: 90px;
            background: white;
            z-index: 100;
        }
        
        /* When FBR is active, reduce Rx area height and shift footers up to avoid overlap */
        .slip-preview.has-fbr .rx-area {
            height: 750px !important;
        }
        .slip-preview.has-fbr.evening-night-mode .rx-area {
            height: 640px !important;
        }
        .slip-preview.has-fbr .evening-night-footer {
            bottom: 35mm !important;
        }
        .slip-preview.has-fbr .us-footer {
            bottom: 32mm !important;
        }
        .slip-preview.has-fbr .ent-footer {
            bottom: 32mm !important;
        }
        .slip-preview.has-fbr .lab-footer {
            bottom: 32mm !important;
        }
        .slip-preview.has-fbr .hij-footer-green {
            bottom: 32mm !important;
        }

        /* Ultrasound Mode Styles */
        .ultrasound-header {
            display: none;
            width: 100%;
            text-align: center;
            border-bottom: 2px solid #b10000;
            padding-bottom: 12px;
            margin-bottom: 15px;
        }

        .ultrasound-logo-title {
            width: 100%;
            margin-bottom: 2px;
        }

        .ultrasound-header-subtitle {
            color: #1c3d5a;
            font-size: 15px;
            font-weight: bold;
            letter-spacing: 1px;
        }

        .ultrasound-header-phone {
            color: #1c3d5a;
            font-size: 15px;
            font-weight: bold;
        }

        .ultrasound-slip-type-container {
            margin-top: 8px;
            text-align: center;
        }

        .ultrasound-body {
            display: none;
            /* hidden by default */
            margin-top: 15px;
            border-top: 2px solid #555;
            padding-top: 15px;
        }

        .us-section-title {
            color: #b10000;
            font-size: 20px;
            font-weight: bold;
            text-align: center;
            text-decoration: underline;
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        .us-row {
            display: flex;
            justify-content: space-between;
            gap: 30px;
        }

        .us-col {
            width: 48%;
        }

        .us-field-row {
            display: flex;
            align-items: flex-end;
            margin-bottom: 10px;
            font-size: 15px;
            font-weight: bold;
        }

        .us-label {
            white-space: nowrap;
            margin-right: 8px;
            color: #333;
        }

        .us-dotted-line {
            flex-grow: 1;
            border-bottom: 1px dotted #444;
            height: 1px;
            margin-bottom: 3px;
        }

        .us-footer {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-top: 25px;
            padding-top: 10px;
        }

        .us-footer-left {
            color: #b10000;
            font-size: 15px;
            font-weight: bold;
        }

        .us-footer-right {
            color: #b10000;
            font-size: 18px;
            font-weight: bold;
            text-align: center;
            border-top: 1px solid #b10000;
            width: 150px;
            padding-top: 5px;
            margin-top: 25px;
        }

        /* Toggle between templates based on ultrasound-mode class */
        .slip-preview.ultrasound-mode .slip-header,
        .slip-preview.ultrasound-mode .evening-night-header,
        .slip-preview.ultrasound-mode .evening-night-footer,
        .slip-preview.ultrasound-mode .rx-area {
            display: none !important;
        }

        .slip-preview.ultrasound-mode .ultrasound-header {
            display: block !important;
        }

        .slip-preview.ultrasound-mode .ultrasound-body {
            display: block !important;
        }

        /* ENT Mode Styles */
        .ent-header {
            display: none;
            width: 100%;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 2px solid #b10000;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }

        .ent-header-left {
            width: 35%;
            color: #233d84;
            font-family: Arial, sans-serif;
        }

        .ent-doc-name-eng {
            font-size: 20px;
            font-weight: bold;
            color: #b10000;
            margin-bottom: 8px;
        }

        .ent-doc-sub-eng {
            font-size: 13px;
            font-weight: bold;
            margin-bottom: 5px;
            line-height: 1.4;
        }

        .ent-doc-spec-eng {
            font-size: 13px;
            font-weight: bold;
            margin-bottom: 5px;
            line-height: 1.4;
        }

        .ent-doc-addr-eng {
            font-size: 12px;
            margin-top: 8px;
            font-weight: bold;
        }

        .ent-header-center {
            width: 30%;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .ent-slip-type-container {
            margin-top: 8px;
        }

        .ent-header-right {
            width: 35%;
            color: #233d84;
            text-align: right;
            direction: rtl;
        }

        .ent-doc-name-urdu {
            font-size: 23px;
            font-weight: bold;
            color: #b10000;
            margin-bottom: 12px;
        }

        .ent-doc-sub-urdu {
            font-size: 14px;
            font-weight: bold;
            margin-bottom: 8px;
            line-height: 2.2 !important;
        }

        .ent-doc-spec-urdu {
            font-size: 14px;
            font-weight: bold;
            margin-bottom: 8px;
            line-height: 2.2 !important;
        }

        .ent-doc-addr-urdu {
            font-size: 13px;
            margin-top: 8px;
            line-height: 2.2 !important;
        }

        .ent-footer {
            display: none;
            position: absolute;
            bottom: 12mm;
            left: 12mm;
            right: 12mm;
            border-top: 1px solid #777;
            padding-top: 10px;
            text-align: center;
            font-size: 13px;
            line-height: 1.8;
            color: #333;
            font-weight: bold;
        }

        /* Toggle between templates based on ent-mode class */
        .slip-preview.ent-mode .slip-header,
        .slip-preview.ent-mode .evening-night-header,
        .slip-preview.ent-mode .evening-night-footer,
        .slip-preview.ent-mode .ultrasound-header,
        .slip-preview.ent-mode .ultrasound-body {
            display: none !important;
        }

        .slip-preview.ent-mode .ent-header {
            display: flex !important;
        }

        .slip-preview.ent-mode .ent-footer {
            display: block !important;
        }

        .slip-preview.ent-mode .patient-info {
            border-top: none !important;
        }

        .slip-preview.ent-mode .rx-area {
            border-top: none !important;
            height: 780px !important;
        }

        .slip-preview.ent-mode .rx-left {
            width: 100% !important;
            border-right: none !important;
        }

        .slip-preview.ent-mode .rx-right {
            display: none !important;
        }

        .ent-hospital-title {
            color: #b10000;
            font-size: 26px;
            font-weight: bold;
            letter-spacing: 2px;
            font-family: Arial, sans-serif;
            margin-bottom: 8px;
            text-align: center;
        }

        .slip-preview.ent-mode .rx-symbol {
            display: none !important;
        }

        /* ==========================================================================
           ENT Operation Consent Slip Mode Styles
           ========================================================================== */
        .ent-operation-body {
            display: none;
            width: 100%;
            direction: rtl;
            text-align: right;
            font-family: 'Noto Nastaliq Urdu', Arial, sans-serif;
            font-size: 11px;
            line-height: 1.6;
            color: #000;
        }

        .slip-preview.ent-operation-mode {
            padding: 8mm 10mm !important;
        }

        .slip-preview.ent-operation-mode .slip-header,
        .slip-preview.ent-operation-mode .evening-night-header,
        .slip-preview.ent-operation-mode .evening-night-footer,
        .slip-preview.ent-operation-mode .ultrasound-header,
        .slip-preview.ent-operation-mode .ultrasound-body,
        .slip-preview.ent-operation-mode .ent-header,
        .slip-preview.ent-operation-mode .ent-footer,
        .slip-preview.ent-operation-mode .rx-area,
        .slip-preview.ent-operation-mode .patient-info,
        .slip-preview.ent-operation-mode .lab-header,
        .slip-preview.ent-operation-mode .lab-patient-info,
        .slip-preview.ent-operation-mode .lab-body,
        .slip-preview.ent-operation-mode .lab-footer {
            display: none !important;
        }

        .slip-preview.ent-operation-mode .ent-operation-body {
            display: block !important;
        }

        .ent-op-banner {
            background-color: #000;
            color: #fff;
            padding: 12px 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-radius: 8px;
            margin-bottom: 8px;
        }

        .ent-op-banner h1 {
            font-size: 22px;
            font-weight: bold;
            margin: 0;
            color: #fff;
            font-family: 'Noto Nastaliq Urdu', serif;
        }

        .ent-op-banner span {
            font-size: 13px;
            font-weight: bold;
        }

        .ent-op-sub-header {
            text-align: center;
            margin-bottom: 10px;
        }

        .ent-op-sub-header .location {
            font-size: 13px;
            font-weight: bold;
            color: #222;
        }

        .ent-op-sub-header .title-ijazat {
            font-size: 18px;
            font-weight: bold;
            color: #b10000;
            margin: 4px 0;
            display: inline-block;
            border: 2px solid #b10000;
            padding: 6px 20px;
            border-radius: 10px;
        }

        .ent-op-sub-header .subtitle {
            font-size: 13px;
            font-weight: bold;
            color: #333;
        }

        .ent-op-info-intro {
            font-size: 11.5px;
            font-weight: bold;
            margin-bottom: 8px;
            border-bottom: 2px solid #777;
            padding-bottom: 18px;
        }

        .ent-op-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        .ent-op-table td {
            vertical-align: top;
            padding: 6px 8px;
            border-bottom: 4px solid #ddd;
        }

        .ent-op-table td.heading-col {
            font-weight: bold;
            font-size: 12px;
            color: #b10000;
            width: 18%;
            border-left: 1px solid #ddd;
            text-align: right;
            padding-right: 0;
        }

        .ent-op-table td.text-col {
            width: 82%;
            text-align: right;
            padding-left: 0;
        }

        .ent-op-table td.text-col div {
            margin-bottom: 4px;
        }

        .ent-op-table td.text-col div:last-child {
            margin-bottom: 0;
        }

        .ent-op-fields {
            margin-top: 40px;
            margin-bottom: 10px;
        }

        .ent-op-fields-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
            gap: 15px;
        }

        .ent-op-field {
            display: flex;
            align-items: flex-end;
            font-size: 11.5px;
            font-weight: bold;
            width: 48%;
        }

        .ent-op-field-label {
            white-space: nowrap;
            margin-left: 8px;
            color: #333;
        }

        .ent-op-field-value {
            border-bottom: 1px dotted #0a0a0b;
            flex-grow: 1;
            padding-right: 8px;
            color: #000;
            min-height: 18px;
        }

        .ent-op-declaration {
            border: 1px solid #777;
            padding: 6px 10px;
            font-size: 10.5px;
            line-height: 1.6;
            margin-bottom: 25px;
            text-align: justify;
            border-radius: 4px;
        }

        .ent-op-note-center {
            text-align: center;
            font-weight: bold;
            font-size: 12px;
            margin-bottom: 20px;
            color: #e70808;
        }

        .ent-op-sigs {
            margin-top: 40px;
            margin-bottom: 5px;
        }

        .ent-op-sig-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 8px;
            gap: 15px;
        }

        .ent-op-sig-col {
            display: flex;
            align-items: flex-end;
            font-size: 11px;
            font-weight: bold;
        }

        .ent-op-sig-col.w-35 {
            width: 35%;
        }

        .ent-op-sig-col.w-30 {
            width: 30%;
        }

        .ent-op-sig-label {
            white-space: nowrap;
            margin-left: 5px;
        }

        .ent-op-sig-line {
            border-bottom: 1px dotted #333;
            flex-grow: 1;
